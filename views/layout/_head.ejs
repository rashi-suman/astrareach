<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'AstraReach' %> — AstraReach</title>
    <link rel="icon" type="image/png" href="/images/logo-main.png">
    <link rel="shortcut icon" href="/images/logo-main.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Inter', 'sans-serif'] },
                    colors: {
                        brand: {
                            dark: '#0f1117',
                            sidebar: '#161b27',
                            card: '#1e2535',
                            border: '#2a3347',
                            primary: '#623CEA',
                            secondary: '#a78bfa',
                            textMuted: '#8b93a7'
                        },
                        primary: '#623CEA',
                        darkBg: '#0f1117',
                        cardBg: '#161b27',
                        border: '#2a3347',
                        textSecondary: '#8b93a7',
                        btnSecondary: '#252d3d',
                        btnBorder: '#334060'
                    }
                }
            }
        }
    </script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/js/all.min.js" crossorigin="anonymous"></script>
    <style>
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: #0f1117; }
        ::-webkit-scrollbar-thumb { background: #334060; border-radius: 10px; }
        .active-nav { border-left: 2px solid #623CEA !important; background: rgba(98,60,234,0.08) !important; color: #623CEA !important; }
        .nav-item:hover:not(.active-nav) { background: #1e2535; color: #e8eaf2; }
        #sidebar { transition: width 0.25s ease; }
        #sidebar.collapsed { width: 60px !important; }
        #sidebar.collapsed .nav-label { display: none; }
        #sidebar.collapsed .sidebar-logo-text { display: none; }
        #sidebar.collapsed .sidebar-footer-info { display: none; }
        #sidebar.collapsed #sidebar-nav a { padding-left: 0; padding-right: 0; justify-content: center; }
        #sidebar.collapsed #sidebar-nav a i { margin-right: 0; }
        /* Keep toggle button visible and centered when collapsed */
        #sidebar.collapsed #sidebar-logo { justify-content: center; padding-left: 8px; padding-right: 8px; gap: 0; }
        #sidebar.collapsed #sidebar-logo .nav-label { display: none; }
        #sidebar.collapsed #sidebar-logo #sidebar-toggle { margin-left: 0; }
        /* Flip the toggle arrow when collapsed */
        #sidebar.collapsed #toggle-icon { transform: rotate(180deg); }
        #sidebar.collapsed #wa-sidebar-submenu,
        #sidebar.collapsed #email-sidebar-submenu { display: none !important; }
        #sidebar.collapsed #wa-sidebar-chevron,
        #sidebar.collapsed #email-sidebar-chevron { display: none !important; }
        #sidebar.collapsed #wa-sidebar-toggle,
        #sidebar.collapsed #email-sidebar-toggle { justify-content: center; padding-left: 0; padding-right: 0; }
        #sidebar.collapsed #wa-sidebar-toggle > i:first-child,
        #sidebar.collapsed #email-sidebar-toggle > i:first-child { margin-right: 0 !important; }
        body.sidebar-collapsed #main-wrapper { margin-left: 60px; }
        #main-wrapper { margin-left: 240px; transition: margin-left 0.25s ease; }
        .table-container { overflow-y: auto; }
        .sticky-header { position: sticky; top: 0; z-index: 10; }
        .dropdown-menu { display: none; }
        .dropdown-menu.open { display: block; }
        /* ── Toast system ── */
        #toast-container { position: fixed; bottom: 24px; right: 24px; z-index: 9999; display: flex; flex-direction: column-reverse; gap: 10px; pointer-events: none; }
        .toast { background: #1e2535; border: 1px solid #2a3347; border-radius: 12px; padding: 13px 16px; font-size: 13px; min-width: 300px; max-width: 420px; display: flex; align-items: flex-start; gap: 11px; box-shadow: 0 8px 32px rgba(0,0,0,0.45); pointer-events: all; cursor: default; animation: toastIn 0.25s cubic-bezier(.16,1,.3,1); transition: opacity 0.2s, transform 0.2s; }
        .toast.hiding { opacity: 0; transform: translateX(20px); }
        .toast-icon { flex-shrink: 0; width: 18px; height: 18px; display: flex; align-items: center; justify-content: center; margin-top: 1px; }
        .toast-body { flex: 1; }
        .toast-title { font-weight: 600; font-size: 13px; line-height: 1.3; }
        .toast-msg { font-size: 12px; color: #8b93a7; margin-top: 2px; line-height: 1.4; }
        .toast-close { flex-shrink: 0; background: none; border: none; color: #8b93a7; cursor: pointer; font-size: 13px; padding: 0 0 0 4px; line-height: 1; margin-top: 1px; }
        .toast-close:hover { color: #e8eaf2; }
        .toast-progress { position: absolute; bottom: 0; left: 0; height: 2px; border-radius: 0 0 12px 12px; transition: width linear; }
        .toast { position: relative; overflow: hidden; }
        .toast.success { border-left: 3px solid #22c55e; }
        .toast.success .toast-icon { color: #22c55e; }
        .toast.success .toast-progress { background: #22c55e; }
        .toast.error { border-left: 3px solid #ef4444; }
        .toast.error .toast-icon { color: #ef4444; }
        .toast.error .toast-progress { background: #ef4444; }
        .toast.warning { border-left: 3px solid #f59e0b; }
        .toast.warning .toast-icon { color: #f59e0b; }
        .toast.warning .toast-progress { background: #f59e0b; }
        .toast.info { border-left: 3px solid #623CEA; }
        .toast.info .toast-icon { color: #623CEA; }
        .toast.info .toast-progress { background: #623CEA; }
        @keyframes toastIn { from { opacity: 0; transform: translateX(24px) scale(0.96); } to { opacity: 1; transform: translateX(0) scale(1); } }
        .drawer { position: fixed; top: 0; right: -600px; width: 560px; height: 100vh; background: #161b27; border-left: 1px solid #2a3347; z-index: 1000; transition: right 0.3s ease; overflow-y: auto; }
        .drawer.open { right: 0; }
        .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 999; display: none; }
        .modal-overlay.open { display: block; }
    </style>
    <script>
    /* ── Global Toast System ── */
    (function(){
        const ICONS = {
            success: '<i class="fa-solid fa-circle-check"></i>',
            error:   '<i class="fa-solid fa-circle-xmark"></i>',
            warning: '<i class="fa-solid fa-triangle-exclamation"></i>',
            info:    '<i class="fa-solid fa-circle-info"></i>',
        };
        const TITLES = { success: 'Success', error: 'Error', warning: 'Warning', info: 'Info' };
        const DURATION = { success: 4000, error: 6000, warning: 5000, info: 4000 };

        window.showToast = function(message, type, title) {
            type = type || 'info';
            if (!message) return;

            let container = document.getElementById('toast-container');
            if (!container) {
                container = document.createElement('div');
                container.id = 'toast-container';
                document.body.appendChild(container);
            }

            const duration = DURATION[type] || 4000;
            const t = document.createElement('div');
            t.className = 'toast ' + type;
            t.innerHTML = `
                <div class="toast-icon">${ICONS[type] || ICONS.info}</div>
                <div class="toast-body">
                    <div class="toast-title">${title || TITLES[type] || 'Notice'}</div>
                    ${message !== (title || TITLES[type]) ? `<div class="toast-msg">${message}</div>` : ''}
                </div>
                <button class="toast-close" onclick="this.closest('.toast')._dismiss()">&#x2715;</button>
                <div class="toast-progress" style="width:100%"></div>`;

            const bar = t.querySelector('.toast-progress');
            t._dismiss = function() {
                t.classList.add('hiding');
                setTimeout(() => t.remove(), 220);
            };

            container.appendChild(t);

            // Animate progress bar
            requestAnimationFrame(() => {
                bar.style.transitionDuration = duration + 'ms';
                bar.style.width = '0%';
            });

            const timer = setTimeout(() => t._dismiss(), duration);

            // Pause on hover
            t.addEventListener('mouseenter', () => {
                clearTimeout(timer);
                bar.style.animationPlayState = 'paused';
                bar.style.transitionDuration = '0ms';
            });
            t.addEventListener('mouseleave', () => {
                const remaining = parseFloat(bar.style.width) / 100 * duration;
                bar.style.transitionDuration = remaining + 'ms';
                bar.style.width = '0%';
                setTimeout(() => t._dismiss(), remaining);
            });

            return t;
        };

        // Shorthand helpers
        window.toastSuccess = (msg, title) => window.showToast(msg, 'success', title);
        window.toastError   = (msg, title) => window.showToast(msg, 'error',   title);
        window.toastWarning = (msg, title) => window.showToast(msg, 'warning', title);
        window.toastInfo    = (msg, title) => window.showToast(msg, 'info',    title);
    })();
    </script>
    <script>
        /* Sidebar — single authoritative handler, runs last via DOMContentLoaded.
           Uses cloneNode to wipe any duplicate handlers added by page-level scripts. */
        document.addEventListener('DOMContentLoaded', function () {
            const sidebar = document.getElementById('sidebar');
            const wrapper = document.getElementById('main-wrapper');
            const oldBtn = document.getElementById('sidebar-toggle');
            if (!oldBtn || !sidebar) return;

            const COLLAPSED_KEY = 'ar_sidebar_collapsed';

            // Restore persisted state first
            if (localStorage.getItem(COLLAPSED_KEY) === '1') {
                sidebar.classList.add('collapsed');
                document.body.classList.add('sidebar-collapsed');
                if (wrapper) wrapper.style.marginLeft = '60px';
            }

            // Clone button → strips ALL duplicate addEventListener bindings from page scripts
            const btn = oldBtn.cloneNode(true);
            oldBtn.parentNode.replaceChild(btn, oldBtn);

            btn.addEventListener('click', function () {
                sidebar.classList.toggle('collapsed');
                const isCollapsed = sidebar.classList.contains('collapsed');
                document.body.classList.toggle('sidebar-collapsed', isCollapsed);
                if (wrapper) wrapper.style.marginLeft = isCollapsed ? '60px' : '240px';
                localStorage.setItem(COLLAPSED_KEY, isCollapsed ? '1' : '0');
            });
        });
    </script>
</head>
