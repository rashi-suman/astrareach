<!DOCTYPE html>
<html lang="en">
<%- include('../layout/_head', { title: 'Templates' }) %>
<body class="bg-brand-dark text-gray-100 font-sans antialiased">
<%- include('../layout/_sidebar', { page: 'templates', user }) %>
<div id="main-wrapper" class="flex flex-col h-screen overflow-hidden">
<%- include('../layout/_header', { breadcrumbs, user }) %>

<div class="flex-1 flex flex-col overflow-hidden min-h-0">

    <!-- Page Header -->
    <div class="h-16 border-b border-brand-border flex items-center justify-between px-8 bg-brand-sidebar/50 backdrop-blur-md shrink-0">
        <div class="flex items-center gap-4">
            <h1 class="text-lg font-semibold">Email Templates</h1>
            <span class="px-2.5 py-0.5 bg-btnSecondary text-brand-textMuted text-xs font-medium rounded-full border border-btnBorder"><%= total.toLocaleString() %> total</span>
        </div>
        <div class="flex items-center gap-2 shrink-0">
            <button onclick="document.getElementById('ai-gen-modal').classList.remove('hidden')"
                class="inline-flex items-center gap-2 px-4 py-2 bg-purple-600/20 border border-purple-500/40 text-purple-400 hover:bg-purple-600/30 rounded-lg text-sm font-semibold transition-all">
                <i class="fa-solid fa-wand-magic-sparkles"></i>AI Generate
            </button>
            <a href="/templates/new" class="inline-flex items-center gap-2 px-4 py-2 bg-brand-primary text-white rounded-lg text-sm font-semibold hover:opacity-90 transition-all">
                <i class="fa-solid fa-plus"></i>New Template
            </a>
        </div>
    </div>

    <!-- Filter + Cards -->
    <section class="flex-1 px-6 pt-3 pb-3 overflow-hidden flex flex-col gap-0 min-h-0">

        <!-- Search Bar -->
        <form id="filter-form" method="GET" action="/templates" class="mb-3 shrink-0">
            <div class="flex flex-wrap items-center gap-2">
                <div class="relative shrink-0" style="min-width:220px;max-width:320px;flex:1 1 220px;">
                    <i class="fa-solid fa-magnifying-glass absolute left-3 top-1/2 -translate-y-1/2 text-brand-textMuted text-xs"></i>
                    <input type="text" name="search" id="tmpl-search" value="<%= query.search || '' %>"
                        placeholder="Search by name or subject..."
                        class="w-full bg-btnSecondary border border-btnBorder rounded-md py-1.5 pl-9 pr-3 text-sm focus:outline-none focus:border-brand-primary transition-all">
                </div>
                <button type="submit" class="px-3 py-1.5 bg-btnSecondary border border-btnBorder rounded-md text-sm hover:bg-brand-border/50 transition-all">
                    <i class="fa-solid fa-filter mr-1 text-xs"></i>Filter
                </button>
                <% if (query.search) { %>
                <a href="/templates" class="text-brand-primary text-sm hover:underline">Clear</a>
                <% } %>
            </div>
        </form>

        <!-- Scrollable Cards -->
        <div class="flex-1 overflow-y-auto min-h-0">
            <% if (!templates || templates.length === 0) { %>
            <div class="flex flex-col items-center justify-center py-20 text-center">
                <div class="w-16 h-16 rounded-full bg-brand-border/30 flex items-center justify-center mx-auto mb-4">
                    <i class="fa-regular fa-file-code text-3xl text-brand-textMuted"></i>
                </div>
                <p class="text-base font-medium text-brand-textMuted mb-1">No templates found</p>
                <p class="text-sm text-brand-textMuted/60 mb-4"><%= query.search ? 'Try a different search term.' : 'Create your first reusable email template.' %></p>
                <% if (!query.search) { %>
                <a href="/templates/new" class="inline-flex items-center gap-2 mt-2 px-5 py-2.5 bg-brand-primary text-white rounded-lg text-sm font-medium">
                    <i class="fa-solid fa-plus"></i>Create Template
                </a>
                <% } %>
            </div>
            <% } else { %>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 pb-2">
                <% templates.forEach(t => { %>
                <div class="bg-brand-card border border-brand-border rounded-xl overflow-hidden hover:border-brand-primary/40 hover:shadow-lg hover:shadow-brand-primary/5 transition-all group">
                    <div class="p-5">
                        <div class="flex items-start justify-between mb-3">
                            <div class="w-9 h-9 rounded-lg bg-amber-500/10 flex items-center justify-center">
                                <i class="fa-regular fa-file-code text-amber-500"></i>
                            </div>
                            <div class="flex gap-1.5">
                                <a href="/templates/<%= t.id %>/edit" class="p-1.5 text-brand-textMuted hover:text-white rounded transition-colors"><i class="fa-solid fa-pen text-xs"></i></a>
                                <% if (user && user.role !== 'editor' && user.role !== 'lead_manager' && user.role !== 'campaign_manager') { %>
                                <form action="/templates/<%= t.id %>" method="POST" class="inline">
                                    <input type="hidden" name="_method" value="DELETE">
                                    <button type="submit" onclick="return confirm('Delete this template?')" class="p-1.5 text-brand-textMuted hover:text-red-400 rounded transition-colors"><i class="fa-solid fa-trash text-xs"></i></button>
                                </form>
                                <% } %>
                            </div>
                        </div>
                        <h3 class="font-semibold mb-1"><a href="/templates/<%= t.id %>" class="hover:text-brand-primary transition-colors"><%= t.name %></a></h3>
                        <p class="text-xs text-brand-textMuted mb-3 line-clamp-1"><%= t.subject %></p>
                        <% if (t.variables && t.variables.length > 0) { %>
                        <div class="flex flex-wrap gap-1.5 mb-3">
                            <% t.variables.slice(0,4).forEach(v => { %><span class="px-2 py-0.5 bg-brand-primary/10 text-brand-primary text-[10px] rounded border border-brand-primary/20">{{<%= v %>}}</span><% }) %>
                            <% if (t.variables.length > 4) { %><span class="px-2 py-0.5 bg-brand-border text-brand-textMuted text-[10px] rounded">+<%= t.variables.length - 4 %></span><% } %>
                        </div>
                        <% } %>
                    </div>
                    <div class="border-t border-brand-border px-5 py-3 flex items-center justify-between bg-brand-sidebar/10">
                        <span class="text-[11px] text-brand-textMuted"><%= new Date(t.created_at).toLocaleDateString() %></span>
                        <a href="/templates/<%= t.id %>" class="text-[11px] text-brand-primary hover:underline">View →</a>
                    </div>
                </div>
                <% }) %>
            </div>
            <% } %>
        </div>

        <!-- Pagination -->
        <% const totalPages = Math.ceil(total / limit); %>
        <% if (totalPages > 1) { %>
        <div class="shrink-0 flex items-center justify-between pt-3">
            <span class="text-xs text-brand-textMuted">
                Showing <%= ((pageNo - 1) * limit + 1).toLocaleString() %>–<%= Math.min(pageNo * limit, total).toLocaleString() %> of <%= total.toLocaleString() %>
            </span>
            <div class="flex items-center gap-1">
                <% if (pageNo > 1) { %>
                <a href="/templates?<%= new URLSearchParams({...query, page: pageNo - 1}).toString() %>"
                    class="px-3 py-1.5 bg-btnSecondary border border-btnBorder rounded text-xs hover:bg-brand-border/50 transition-all">
                    <i class="fa-solid fa-chevron-left text-[10px] mr-1"></i>Prev
                </a>
                <% } %>
                <%
                    const startPg = Math.max(1, pageNo - 2);
                    const endPg   = Math.min(totalPages, pageNo + 2);
                    for (let p = startPg; p <= endPg; p++) { %>
                <a href="/templates?<%= new URLSearchParams({...query, page: p}).toString() %>"
                    class="px-3 py-1.5 border rounded text-xs transition-all <%= p === pageNo ? 'bg-brand-primary border-brand-primary text-white' : 'bg-btnSecondary border-btnBorder hover:bg-brand-border/50' %>">
                    <%= p %>
                </a>
                <% } %>
                <% if (pageNo < totalPages) { %>
                <a href="/templates?<%= new URLSearchParams({...query, page: pageNo + 1}).toString() %>"
                    class="px-3 py-1.5 bg-btnSecondary border border-btnBorder rounded text-xs hover:bg-brand-border/50 transition-all">
                    Next<i class="fa-solid fa-chevron-right text-[10px] ml-1"></i>
                </a>
                <% } %>
            </div>
        </div>
        <% } %>

    </section>
</div>
</div>

<!-- AI Generate Template Modal -->
<div id="ai-gen-modal" class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center p-4">
  <div class="bg-brand-card border border-brand-border rounded-2xl w-full max-w-md shadow-2xl">
    <div class="flex items-center justify-between px-6 py-4 border-b border-brand-border">
      <div class="flex items-center gap-2">
        <i class="fa-solid fa-wand-magic-sparkles text-purple-400"></i>
        <h3 class="font-semibold text-sm">AI Template Generator</h3>
      </div>
      <button onclick="document.getElementById('ai-gen-modal').classList.add('hidden')" class="text-brand-textMuted hover:text-white">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>
    <form action="/templates/ai-generate" method="POST" class="p-6 space-y-4">
      <div>
        <label class="block text-xs font-medium text-brand-textMuted uppercase tracking-wide mb-1.5">Industry</label>
        <input type="text" name="industry" placeholder="e.g. SaaS, FinTech, Healthcare" required
          class="w-full bg-brand-sidebar border border-brand-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-brand-primary">
      </div>
      <div>
        <label class="block text-xs font-medium text-brand-textMuted uppercase tracking-wide mb-1.5">Target Job Title</label>
        <input type="text" name="avg_contact_job_title" placeholder="e.g. VP of Sales, CTO" required
          class="w-full bg-brand-sidebar border border-brand-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-brand-primary">
      </div>
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="block text-xs font-medium text-brand-textMuted uppercase tracking-wide mb-1.5">Tone</label>
          <select name="tone" class="w-full bg-brand-sidebar border border-brand-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-brand-primary">
            <option value="professional">Professional</option>
            <option value="friendly">Friendly</option>
            <option value="direct">Direct</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-medium text-brand-textMuted uppercase tracking-wide mb-1.5">Goal</label>
          <select name="goal" class="w-full bg-brand-sidebar border border-brand-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-brand-primary">
            <option value="book call">Book a Call</option>
            <option value="demo">Request Demo</option>
            <option value="reply">Get a Reply</option>
          </select>
        </div>
      </div>
      <div>
        <label class="block text-xs font-medium text-brand-textMuted uppercase tracking-wide mb-1.5">Company Size</label>
        <input type="text" name="company_size" placeholder="e.g. 50-500 employees" value="50-500 employees"
          class="w-full bg-brand-sidebar border border-brand-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-brand-primary">
      </div>
      <button type="submit" id="ai-gen-btn" class="w-full py-2.5 bg-purple-600 hover:bg-purple-500 text-white rounded-lg text-sm font-medium transition-all flex items-center justify-center gap-2">
        <i class="fa-solid fa-wand-magic-sparkles"></i>Generate with AI
      </button>
    </form>
  </div>
</div>

<div id="toast-container"></div>
<script>
(function(){
    const btn=document.getElementById('sidebar-toggle');
    const sidebar=document.getElementById('sidebar');
    const wrapper=document.getElementById('main-wrapper');
    if(btn)btn.addEventListener('click',()=>{sidebar.classList.toggle('collapsed');wrapper.style.marginLeft=sidebar.classList.contains('collapsed')?'60px':'240px';});

    const aiForm = document.querySelector('#ai-gen-modal form');
    const aiBtn  = document.getElementById('ai-gen-btn');
    if (aiForm) aiForm.addEventListener('submit', () => {
        aiBtn.disabled = true;
        aiBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Generating…';
    });

    // Auto-submit search on typing
    const searchInput = document.getElementById('tmpl-search');
    if (searchInput) {
        let searchTimer;
        searchInput.addEventListener('input', function() {
            clearTimeout(searchTimer);
            searchTimer = setTimeout(() => document.getElementById('filter-form').submit(), 600);
        });
    }
})();
</script>
</body>
</html>
