<!DOCTYPE html>
<html lang="en">
<%- include('../layout/_head', { title: 'Edit Template' }) %>
<body class="bg-brand-dark text-gray-100 font-sans antialiased">
<%- include('../layout/_sidebar', { page: 'templates', user }) %>
<div id="main-wrapper" class="flex flex-col min-h-screen">
<%- include('../layout/_header', { breadcrumbs, user }) %>
<main class="flex-1 overflow-y-auto p-6">
<div class="max-w-4xl mx-auto">

    <div class="flex items-center justify-between mb-6">
        <h1 class="text-xl font-semibold">Edit Template</h1>
        <div class="flex items-center gap-3">
            <button type="button" onclick="openPreviewModal()" class="px-4 py-2 bg-btnSecondary border border-btnBorder rounded-lg text-sm hover:bg-brand-border/50 transition-all flex items-center gap-2">
                <i class="fa-solid fa-expand text-xs"></i>Full Preview
            </button>
            <a href="/templates" class="text-sm text-brand-textMuted hover:text-white transition-colors"><i class="fa-solid fa-arrow-left mr-1.5"></i>Back</a>
        </div>
    </div>

    <form action="/templates/<%= template.id %>" method="POST" class="grid grid-cols-1 lg:grid-cols-5 gap-6">
        <input type="hidden" name="_method" value="PUT">
        <div class="lg:col-span-3 space-y-5">
            <div class="bg-brand-card border border-brand-border rounded-xl p-5 space-y-4">
                <div>
                    <label class="block text-xs font-medium text-brand-textMuted uppercase tracking-wide mb-1.5">Template Name *</label>
                    <input type="text" name="name" value="<%= template.name %>" required
                        class="w-full bg-btnSecondary border border-btnBorder rounded-lg py-2.5 px-3.5 text-sm focus:outline-none focus:border-brand-primary transition-all">
                </div>
                <div>
                    <label class="block text-xs font-medium text-brand-textMuted uppercase tracking-wide mb-1.5">Subject Line *</label>
                    <input type="text" name="subject" id="subject-input" value="<%= template.subject %>" required
                        class="w-full bg-btnSecondary border border-btnBorder rounded-lg py-2.5 px-3.5 text-sm focus:outline-none focus:border-brand-primary transition-all">
                </div>
                <div>
                    <label class="block text-xs font-medium text-brand-textMuted uppercase tracking-wide mb-1.5">Preview Text</label>
                    <input type="text" name="preview_text" value="<%= template.preview_text || '' %>"
                        class="w-full bg-btnSecondary border border-btnBorder rounded-lg py-2.5 px-3.5 text-sm focus:outline-none focus:border-brand-primary transition-all">
                </div>
                <div>
                    <label class="block text-xs font-medium text-brand-textMuted uppercase tracking-wide mb-1.5">Booking / CTA URL <span class="text-brand-textMuted font-normal normal-case">(optional — use <code class="text-brand-primary">{{booking_url}}</code> in body)</span></label>
                    <input type="url" name="booking_url" value="<%= template.booking_url || '' %>" placeholder="https://calendly.com/your-link"
                        class="w-full bg-btnSecondary border border-btnBorder rounded-lg py-2.5 px-3.5 text-sm focus:outline-none focus:border-brand-primary transition-all">
                </div>

                <!-- Unsubscribe footer toggle -->
                <div class="p-4 bg-brand-dark border border-brand-border rounded-lg flex items-start gap-3">
                    <div class="mt-0.5">
                        <input type="checkbox" name="include_unsubscribe" id="include_unsubscribe" value="on"
                            <%= template.include_unsubscribe ? 'checked' : '' %>
                            class="w-4 h-4 rounded accent-brand-primary cursor-pointer">
                    </div>
                    <div>
                        <label for="include_unsubscribe" class="text-sm font-medium cursor-pointer select-none">Include Unsubscribe Link</label>
                        <p class="text-xs text-brand-textMuted mt-0.5">When checked, an unsubscribe footer ("Unsubscribe · Pause 30 days") will be automatically appended to the bottom of the email. Leave unchecked to send only the content you write above.</p>
                    </div>
                </div>
                <div>
                    <label class="block text-xs font-medium text-brand-textMuted uppercase tracking-wide mb-1.5">Email Body (HTML) *</label>
                    <textarea name="body_html" id="body-input" required rows="14"
                        class="w-full bg-btnSecondary border border-btnBorder rounded-lg py-2.5 px-3.5 text-sm font-mono focus:outline-none focus:border-brand-primary transition-all resize-y"><%= template.body_html %></textarea>
                </div>
            </div>
            <div class="flex items-center justify-between">
                <a href="/templates/<%= template.id %>" class="px-5 py-2.5 bg-btnSecondary border border-btnBorder rounded-lg text-sm hover:bg-brand-border/50 transition-all">Cancel</a>
                <button type="submit" class="px-6 py-2.5 bg-brand-primary text-white rounded-lg text-sm font-semibold hover:bg-blue-500 transition-all">
                    <i class="fa-solid fa-save mr-2"></i>Save Changes
                </button>
            </div>
        </div>

        <div class="lg:col-span-2 space-y-4">
            <div class="bg-brand-card border border-brand-border rounded-xl p-5">
                <h3 class="text-sm font-semibold mb-3">Available Variables</h3>
                <div class="flex flex-wrap gap-1.5">
                    <% ['first_name','last_name','company','job_title','industry','city','country','website','booking_url'].forEach(v => { %>
                    <button type="button" class="var-chip px-2.5 py-1 bg-brand-primary/10 border border-brand-primary/20 text-brand-primary text-xs rounded hover:bg-brand-primary/20 transition-colors" data-var="<%= v %>">{{<%= v %>}}</button>
                    <% }) %>
                </div>
            </div>
            <div class="bg-brand-card border border-brand-border rounded-xl overflow-hidden">
                <div class="p-4 border-b border-brand-border"><span class="text-sm font-semibold">Live Preview</span></div>
                <div class="p-4 bg-white rounded-b-xl">
                    <iframe id="preview-frame" class="w-full" style="height:300px;border:none;"></iframe>
                </div>
            </div>
        </div>
    </form>
</div>
</main>
</div>

<!-- Full Preview Modal -->
<div id="preview-modal" class="fixed inset-0 bg-black/80 backdrop-blur-sm z-50 hidden flex-col" style="display:none;">
    <div class="flex items-center justify-between px-5 py-3 bg-[#1a1a2e] border-b border-brand-border shrink-0">
        <div class="flex items-center gap-3">
            <i class="fa-solid fa-envelope text-brand-primary text-sm"></i>
            <div>
                <p class="text-sm font-semibold text-white" id="modal-subject-label">Email Preview</p>
                <p class="text-xs text-brand-textMuted">Previewing with sample data (Rohit / Astrabyte)</p>
            </div>
        </div>
        <button onclick="closePreviewModal()" class="w-8 h-8 flex items-center justify-center rounded-lg bg-brand-border/50 hover:bg-red-500/20 hover:text-red-400 transition-all text-brand-textMuted">
            <i class="fa-solid fa-xmark text-sm"></i>
        </button>
    </div>
    <div class="flex items-center justify-center gap-2 py-2 bg-[#111] border-b border-brand-border shrink-0">
        <button onclick="setPreviewWidth('100%')" id="pw-desktop" class="px-3 py-1 rounded text-xs bg-brand-primary/20 text-brand-primary border border-brand-primary/30"><i class="fa-solid fa-desktop mr-1"></i>Desktop</button>
        <button onclick="setPreviewWidth('640px')" id="pw-tablet" class="px-3 py-1 rounded text-xs text-brand-textMuted hover:text-white border border-transparent hover:border-brand-border transition-all"><i class="fa-solid fa-tablet-screen-button mr-1"></i>Tablet</button>
        <button onclick="setPreviewWidth('390px')" id="pw-mobile" class="px-3 py-1 rounded text-xs text-brand-textMuted hover:text-white border border-transparent hover:border-brand-border transition-all"><i class="fa-solid fa-mobile-screen mr-1"></i>Mobile</button>
    </div>
    <div class="flex-1 overflow-auto bg-[#222] flex items-start justify-center p-6">
        <div id="preview-modal-wrapper" style="width:100%;max-width:100%;transition:width 0.25s ease;background:#fff;border-radius:12px;overflow:hidden;box-shadow:0 25px 60px rgba(0,0,0,0.5);">
            <iframe id="preview-modal-frame" style="width:100%;min-height:80vh;border:none;display:block;" srcdoc=""></iframe>
        </div>
    </div>
</div>

<script>
(function(){
    const btn=document.getElementById('sidebar-toggle');const sidebar=document.getElementById('sidebar');const wrapper=document.getElementById('main-wrapper');
    if(btn)btn.addEventListener('click',()=>{sidebar.classList.toggle('collapsed');wrapper.style.marginLeft=sidebar.classList.contains('collapsed')?'60px':'240px';});

    let lastInput = null;
    document.querySelectorAll('input, textarea').forEach(el => el.addEventListener('focus', () => lastInput = el));
    document.querySelectorAll('.var-chip').forEach(chip => {
        chip.addEventListener('click', () => {
            const v = '{{' + chip.dataset.var + '}}';
            if (lastInput) { const s=lastInput.selectionStart,e=lastInput.selectionEnd; lastInput.value=lastInput.value.slice(0,s)+v+lastInput.value.slice(e); lastInput.focus(); lastInput.selectionStart=lastInput.selectionEnd=s+v.length; }
        });
    });

    const bodyInput = document.getElementById('body-input');
    const frame = document.getElementById('preview-frame');
    let timer;
    function updatePreview() { if (frame && bodyInput) frame.srcdoc = bodyInput.value || '...'; }
    if (bodyInput) { bodyInput.addEventListener('input', () => { clearTimeout(timer); timer = setTimeout(updatePreview, 300); }); updatePreview(); }
})();

const _sampleData = {
    first_name:'Rohit', last_name:'Sharma', company:'Astrabyte', job_title:'Founder',
    industry:'IT & Software', city:'Bangalore', country:'India',
    website:'https://astrabytesolutions.com', booking_url:'https://astrabytesolutions.com/book-call'
};

function _applyVars(html) {
    let out = html;
    Object.entries(_sampleData).forEach(([k,v]) => { out = out.split('{{'+k+'}}').join(v); });
    return out;
}

function openPreviewModal() {
    const html  = document.getElementById('body-input')?.value || '';
    const subj  = document.getElementById('subject-input')?.value || 'Email Preview';
    const modal = document.getElementById('preview-modal');
    document.getElementById('modal-subject-label').textContent = _applyVars(subj);
    document.getElementById('preview-modal-frame').srcdoc = _applyVars(html) ||
        '<p style="color:#888;padding:40px;font-family:Inter,sans-serif;">No content yet — start writing in the email body.</p>';
    modal.style.display = 'flex';
    modal.style.flexDirection = 'column';
    document.body.style.overflow = 'hidden';
}

function closePreviewModal() {
    document.getElementById('preview-modal').style.display = 'none';
    document.body.style.overflow = '';
}

function setPreviewWidth(w) {
    const wrap = document.getElementById('preview-modal-wrapper');
    wrap.style.width = w; wrap.style.maxWidth = w;
    ['pw-desktop','pw-tablet','pw-mobile'].forEach(id => {
        document.getElementById(id).className = 'px-3 py-1 rounded text-xs text-brand-textMuted hover:text-white border border-transparent hover:border-brand-border transition-all';
        document.getElementById(id).style.cssText = '';
    });
    const map = {'100%':'pw-desktop','640px':'pw-tablet','390px':'pw-mobile'};
    const el = document.getElementById(map[w]);
    if (el) el.className = 'px-3 py-1 rounded text-xs border border-brand-primary/30';
    if (el) el.style.cssText = 'background:rgba(98,60,234,0.2);color:#a78bfa;';
}

document.addEventListener('keydown', e => { if (e.key === 'Escape') closePreviewModal(); });
</script>
</body>
</html>
