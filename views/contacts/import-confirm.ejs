<!DOCTYPE html>
<html lang="en">
<%- include('../layout/_head', { title: 'Map Columns' }) %>
<body class="bg-brand-dark text-gray-100 font-sans antialiased">
<%- include('../layout/_sidebar', { page: 'contacts', user }) %>
<div id="main-wrapper" class="flex flex-col min-h-screen">
<%- include('../layout/_header', { breadcrumbs, user }) %>
<main class="flex-1 overflow-y-auto p-6">
<div class="max-w-5xl mx-auto space-y-6">

    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-white">Map Columns</h1>
            <div class="flex items-center gap-2 mt-1">
                <i class="fa-solid fa-file-excel text-green-400 text-sm"></i>
                <input
                    id="import-label"
                    name="importLabel"
                    type="text"
                    value="<%= filename.replace(/\.[^.]+$/, '') %>"
                    maxlength="120"
                    class="bg-transparent border-b border-brand-border focus:border-brand-primary outline-none text-sm font-medium text-white w-72 py-0.5 transition-colors placeholder-brand-textMuted"
                    placeholder="Give this import a name…"
                    title="Edit import name"
                >
                <span class="text-brand-textMuted text-xs">· <span class="text-green-400 font-medium"><%= totalRows.toLocaleString() %></span> rows</span>
            </div>
        </div>
        <div class="flex items-center gap-2">
            <div class="flex items-center gap-1.5 text-xs">
                <div class="w-5 h-5 rounded-full bg-brand-primary flex items-center justify-center text-white font-bold text-[10px]">1</div>
                <span class="text-brand-textMuted">Upload</span>
            </div>
            <div class="h-px w-8 bg-brand-border"></div>
            <div class="flex items-center gap-1.5 text-xs">
                <div class="w-5 h-5 rounded-full bg-brand-primary flex items-center justify-center text-white font-bold text-[10px]">2</div>
                <span class="text-white font-medium">Map Columns</span>
            </div>
            <div class="h-px w-8 bg-brand-border"></div>
            <div class="flex items-center gap-1.5 text-xs">
                <div class="w-5 h-5 rounded-full bg-brand-border text-brand-textMuted flex items-center justify-center font-bold text-[10px]">3</div>
                <span class="text-brand-textMuted">Import</span>
            </div>
        </div>
    </div>

    <form action="/contacts/import/confirm" method="POST" id="confirm-form">
        <input type="hidden" name="batchId" value="<%= batchId %>">
        <input type="hidden" name="filePath" value="<%= filePath %>">
        <input type="hidden" name="fileType" value="<%= fileType %>">

        <!-- Column Mapping Table -->
        <div class="bg-brand-card border border-brand-border rounded-xl overflow-hidden">
            <div class="p-5 border-b border-brand-border flex items-center justify-between">
                <h2 class="font-semibold">Column Mapping</h2>
                <span class="text-xs text-brand-textMuted">AI detected <%= Object.values(mapping).filter(v => v && v !== '__skip__').length %> fields</span>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead class="bg-brand-sidebar/30 text-[11px] uppercase tracking-wider text-brand-textMuted border-b border-brand-border">
                        <tr>
                            <th class="px-5 py-3 text-left font-medium w-[180px]">CRM Field</th>
                            <th class="px-5 py-3 text-left font-medium w-[180px]">Map to Column</th>
                            <th class="px-5 py-3 text-left font-medium">Sample Values</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-brand-border/40">
                        <% const crmFields = ['email', 'first_name', 'last_name', 'company', 'job_title', 'phone', 'website', 'industry', 'city', 'country', 'linkedin_url', 'revenue_range', 'employee_count'];
                        crmFields.forEach(field => {
                            const mappedCol = mapping[field];
                            const samples = mappedCol && sampleData[mappedCol] ? sampleData[mappedCol].slice(0,3) : [];
                            const isRequired = field === 'email';
                        %>
                        <tr class="hover:bg-brand-sidebar/20 transition-colors">
                            <td class="px-5 py-3.5 font-medium">
                                <span class="<%= isRequired ? 'text-white' : 'text-brand-textMuted' %>">
                                    <%= field.replace(/_/g, ' ') %>
                                    <% if (isRequired) { %><span class="text-red-400 ml-1">*</span><% } %>
                                </span>
                            </td>
                            <td class="px-5 py-3.5">
                                <select name="mapping[<%= field %>]" class="bg-btnSecondary border border-btnBorder rounded-md py-1.5 px-3 text-sm focus:outline-none focus:border-brand-primary w-full">
                                    <option value="">— Skip —</option>
                                    <% headers.forEach(h => { %>
                                    <option value="<%= h %>" <%= mappedCol === h ? 'selected' : '' %>><%= h %></option>
                                    <% }) %>
                                </select>
                            </td>
                            <td class="px-5 py-3.5 text-brand-textMuted text-xs">
                                <% if (samples.length > 0) { %>
                                <div class="flex gap-2">
                                    <% samples.forEach(s => { %><span class="px-2 py-0.5 bg-brand-border/40 rounded text-[11px] truncate max-w-[120px]"><%= s %></span><% }) %>
                                </div>
                                <% } else { %><span class="text-brand-textMuted/40 italic">No samples</span><% } %>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Unmapped columns as custom fields -->
        <% const unmapped = headers.filter(h => !Object.values(mapping).includes(h)); %>
        <% if (unmapped.length > 0) { %>
        <div class="bg-brand-card border border-brand-border rounded-xl p-5">
            <h3 class="font-semibold mb-3">Unmapped Columns → Custom Fields</h3>
            <p class="text-xs text-brand-textMuted mb-4">These columns will be stored as custom fields (key-value pairs on each contact)</p>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
                <% unmapped.forEach(h => { %>
                <label class="flex items-center gap-3 p-3 bg-brand-dark border border-brand-border rounded-lg cursor-pointer hover:border-brand-primary/50 transition-all">
                    <input type="checkbox" name="customFields[]" value="<%= h %>" checked class="rounded border-btnBorder bg-transparent">
                    <div>
                        <p class="text-xs font-medium text-white"><%= h %></p>
                        <% const samples = sampleData[h] ? sampleData[h].slice(0,1) : []; %>
                        <% if (samples[0]) { %><p class="text-[10px] text-brand-textMuted truncate"><%= samples[0] %></p><% } %>
                    </div>
                </label>
                <% }) %>
            </div>
        </div>
        <% } %>

        <!-- Duplicate Handling -->
        <div class="bg-brand-card border border-brand-border rounded-xl p-5">
            <h3 class="font-semibold mb-3">Duplicate Handling</h3>
            <p class="text-xs text-brand-textMuted mb-4">What to do when an email already exists in your database?</p>
            <div class="flex flex-col sm:flex-row gap-3">
                <label class="flex items-start gap-3 p-4 border border-brand-border rounded-xl cursor-pointer hover:border-brand-primary/50 transition-all flex-1 has-[:checked]:border-brand-primary has-[:checked]:bg-brand-primary/5">
                    <input type="radio" name="duplicateHandling" value="skip" checked class="mt-0.5">
                    <div>
                        <p class="text-sm font-medium">Skip Duplicates</p>
                        <p class="text-xs text-brand-textMuted mt-0.5">Keep existing data, ignore new row</p>
                    </div>
                </label>
                <label class="flex items-start gap-3 p-4 border border-brand-border rounded-xl cursor-pointer hover:border-brand-primary/50 transition-all flex-1 has-[:checked]:border-brand-primary has-[:checked]:bg-brand-primary/5">
                    <input type="radio" name="duplicateHandling" value="update" class="mt-0.5">
                    <div>
                        <p class="text-sm font-medium">Update Existing</p>
                        <p class="text-xs text-brand-textMuted mt-0.5">Overwrite with new data from file</p>
                    </div>
                </label>
            </div>
        </div>

        <!-- Submit -->
        <div class="flex items-center justify-between">
            <a href="/contacts/import" class="px-5 py-2.5 bg-btnSecondary border border-btnBorder rounded-lg text-sm font-medium hover:bg-brand-border/50 transition-all">
                <i class="fa-solid fa-arrow-left mr-2"></i>Back
            </a>
            <button type="submit" class="px-6 py-2.5 bg-brand-primary text-white rounded-lg text-sm font-semibold hover:bg-blue-500 transition-all">
                <i class="fa-solid fa-rocket mr-2"></i>Start Import
            </button>
        </div>
    </form>
</div>
</main>
</div>
<div id="toast-container"></div>
<script>
(function(){
    const btn=document.getElementById('sidebar-toggle');const sidebar=document.getElementById('sidebar');const wrapper=document.getElementById('main-wrapper');
    if(btn)btn.addEventListener('click',()=>{sidebar.classList.toggle('collapsed');wrapper.style.marginLeft=sidebar.classList.contains('collapsed')?'60px':'240px';});
})();
</script>
</body>
</html>
