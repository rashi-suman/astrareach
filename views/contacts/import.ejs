<!DOCTYPE html>
<html lang="en">
<%- include('../layout/_head', { title: 'Import Contacts' }) %>
<body class="bg-brand-dark text-gray-100 font-sans antialiased">
<%- include('../layout/_sidebar', { page: 'contacts', user }) %>
<div id="main-wrapper" class="flex flex-col min-h-screen">
<%- include('../layout/_header', { breadcrumbs, user }) %>
<main class="flex-1 overflow-y-auto p-6">
<div class="max-w-5xl mx-auto space-y-6">

    <div>
        <h1 class="text-2xl font-bold text-white mb-1">Import Contacts</h1>
        <p class="text-brand-textMuted text-sm">Upload your Excel or CSV file to add contacts in bulk</p>
                </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Upload Zone -->
        <div class="lg:col-span-2 space-y-5">
            <form id="upload-form" action="/contacts/import" method="POST" enctype="multipart/form-data">
                <div id="upload-zone"
                    class="bg-brand-card border-2 border-dashed border-brand-border rounded-2xl p-16 text-center flex flex-col items-center justify-center transition-all hover:border-brand-primary cursor-pointer group"
                    onclick="document.getElementById('file-input').click()">
                    <div class="w-16 h-16 bg-brand-primary/10 rounded-full flex items-center justify-center mb-5 group-hover:scale-110 transition-transform">
                        <i class="fa-solid fa-cloud-arrow-up text-2xl text-brand-primary"></i>
            </div>
                    <h3 class="text-white text-base font-semibold mb-1.5">Drag &amp; drop your file here</h3>
                    <p class="text-brand-textMuted text-sm mb-5">or click to browse</p>
                    <div class="flex gap-2 mb-4">
                        <span class="px-3 py-1 bg-brand-dark border border-brand-border rounded-full text-xs text-brand-textMuted">.xlsx</span>
                        <span class="px-3 py-1 bg-brand-dark border border-brand-border rounded-full text-xs text-brand-textMuted">.xls</span>
                        <span class="px-3 py-1 bg-brand-dark border border-brand-border rounded-full text-xs text-brand-textMuted">.csv</span>
        </div>
                    <p class="text-brand-textMuted/60 text-xs">Maximum file size: 50MB · Up to 1,000,000+ rows</p>
                    <div id="file-name-display" class="hidden mt-4 px-4 py-2 bg-brand-primary/10 border border-brand-primary/30 rounded-lg text-sm text-brand-primary font-medium"></div>
                    <input type="file" id="file-input" name="file" accept=".xlsx,.xls,.csv" class="hidden">
                </div>

                <div id="upload-progress" class="hidden mt-4">
                    <div class="flex items-center justify-between text-sm mb-2">
                        <span class="text-brand-textMuted">Analyzing file...</span>
                        <span id="upload-pct" class="text-brand-primary font-medium">0%</span>
            </div>
                    <div class="w-full h-1.5 bg-brand-border rounded-full overflow-hidden">
                        <div id="upload-bar" class="h-full bg-brand-primary rounded-full transition-all" style="width:0%"></div>
            </div>
                </div>

                <button type="submit" id="upload-btn"
                    class="hidden mt-4 w-full py-3 bg-brand-primary text-white font-semibold rounded-xl hover:bg-blue-500 transition-all text-sm">
                    <i class="fa-solid fa-upload mr-2"></i>Upload &amp; Detect Columns
                </button>
            </form>

                    <!-- AI Callout -->
            <div class="bg-brand-primary/5 border border-brand-primary/20 rounded-xl p-4 flex items-start gap-4">
                <div class="w-8 h-8 rounded-lg bg-brand-primary/15 flex items-center justify-center shrink-0">
                    <i class="fa-solid fa-bolt text-brand-primary text-sm"></i>
                        </div>
                        <div>
                    <p class="text-white text-sm font-semibold mb-0.5">Smart AI Column Mapping</p>
                    <p class="text-brand-textMuted text-xs leading-relaxed">Our AI automatically detects and maps your column headers to CRM fields — no manual setup needed. Any unmapped columns become custom fields.</p>
                        </div>
                    </div>

                    <!-- Recent Imports -->
            <div class="bg-brand-card border border-brand-border rounded-xl overflow-hidden">
                <div class="p-5 border-b border-brand-border flex items-center justify-between">
                    <h2 class="font-semibold">Recent Imports</h2>
                        </div>
                <% if (!batches || batches.length === 0) { %>
                <p class="p-6 text-sm text-brand-textMuted text-center">No imports yet</p>
                <% } else { %>
                <table class="w-full text-sm">
                    <thead class="bg-brand-sidebar/30 text-[11px] uppercase tracking-wider text-brand-textMuted border-b border-brand-border">
                        <tr>
                            <th class="px-5 py-3 text-left font-medium">Filename</th>
                            <th class="px-5 py-3 text-left font-medium">Status</th>
                            <th class="px-5 py-3 text-left font-medium">Imported</th>
                            <th class="px-5 py-3 text-left font-medium">Date</th>
                                    </tr>
                                </thead>
                    <tbody class="divide-y divide-brand-border/40">
                        <% batches.forEach(b => { %>
                        <tr class="hover:bg-brand-sidebar/20 transition-colors">
                            <td class="px-5 py-3.5 text-white font-medium truncate max-w-[200px]"><%= b.filename || 'Unknown' %></td>
                            <td class="px-5 py-3.5">
                                <span class="px-2 py-0.5 rounded-full text-[10px] font-bold border
                                    <%= b.status === 'done' ? 'bg-green-500/10 text-green-500 border-green-500/20' :
                                        b.status === 'failed' ? 'bg-red-500/10 text-red-500 border-red-500/20' :
                                        'bg-amber-500/10 text-amber-500 border-amber-500/20' %>">
                                    <%= b.status.toUpperCase() %>
                                            </span>
                                        </td>
                            <td class="px-5 py-3.5 text-brand-textMuted"><%= (b.imported_rows||0).toLocaleString() %> / <%= (b.total_rows||0).toLocaleString() %></td>
                            <td class="px-5 py-3.5 text-brand-textMuted"><%= new Date(b.created_at).toLocaleDateString() %></td>
                                    </tr>
                        <% }) %>
                                </tbody>
                            </table>
                <% } %>
                    </div>
                </div>

        <!-- Right: Tips -->
        <div class="space-y-4">
            <div class="bg-brand-card border border-brand-border rounded-xl p-5">
                <h3 class="font-semibold mb-4 flex items-center gap-2">
                    <i class="fa-solid fa-circle-info text-brand-primary"></i>
                    File Requirements
                </h3>
                <ul class="space-y-3 text-sm text-brand-textMuted">
                    <li class="flex items-start gap-2"><i class="fa-solid fa-check text-green-500 mt-0.5 text-xs"></i>First row must be column headers</li>
                    <li class="flex items-start gap-2"><i class="fa-solid fa-check text-green-500 mt-0.5 text-xs"></i>Email column is required</li>
                    <li class="flex items-start gap-2"><i class="fa-solid fa-check text-green-500 mt-0.5 text-xs"></i>Supports .xlsx, .xls, .csv</li>
                    <li class="flex items-start gap-2"><i class="fa-solid fa-check text-green-500 mt-0.5 text-xs"></i>Max 50MB file size</li>
                    <li class="flex items-start gap-2"><i class="fa-solid fa-check text-green-500 mt-0.5 text-xs"></i>Duplicates are handled automatically</li>
                </ul>
                                </div>
            <div class="bg-brand-card border border-brand-border rounded-xl p-5">
                <h3 class="font-semibold mb-4">Mapped CRM Fields</h3>
                <div class="space-y-2 text-xs text-brand-textMuted">
                    <% ['email *', 'first_name', 'last_name', 'company', 'job_title', 'phone', 'website', 'industry', 'city', 'country', 'linkedin_url', 'revenue_range', 'employee_count'].forEach(f => { %>
                    <div class="flex items-center gap-2">
                        <i class="fa-solid fa-tag text-brand-primary/60 text-[10px]"></i>
                        <span class="<%= f.includes('*') ? 'text-white font-medium' : '' %>"><%= f %></span>
                    </div>
                    <% }) %>
                    <p class="text-brand-textMuted/60 pt-2">+ any other column → custom_fields</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>
<div id="toast-container"></div>
<script>
(function(){
    const btn=document.getElementById('sidebar-toggle');
    const sidebar=document.getElementById('sidebar');
    const wrapper=document.getElementById('main-wrapper');
    if(btn)btn.addEventListener('click',()=>{sidebar.classList.toggle('collapsed');wrapper.style.marginLeft=sidebar.classList.contains('collapsed')?'60px':'240px';});

    const fileInput = document.getElementById('file-input');
    const uploadZone = document.getElementById('upload-zone');
    const fileNameDisplay = document.getElementById('file-name-display');
    const uploadBtn = document.getElementById('upload-btn');

    if (fileInput) {
        fileInput.addEventListener('change', () => {
            if (fileInput.files[0]) {
                fileNameDisplay.textContent = fileInput.files[0].name + ' (' + (fileInput.files[0].size / 1024 / 1024).toFixed(1) + 'MB)';
                fileNameDisplay.classList.remove('hidden');
                uploadBtn.classList.remove('hidden');
            }
        });
    }

    // Drag and drop
    if (uploadZone) {
        uploadZone.addEventListener('dragover', (e) => { e.preventDefault(); uploadZone.classList.add('border-brand-primary'); });
        uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('border-brand-primary'));
        uploadZone.addEventListener('drop', (e) => {
            e.preventDefault();
            uploadZone.classList.remove('border-brand-primary');
            if (e.dataTransfer.files[0]) {
                fileInput.files = e.dataTransfer.files;
                fileInput.dispatchEvent(new Event('change'));
            }
        });
    }

    // Show progress on submit
    document.getElementById('upload-form').addEventListener('submit', () => {
        document.getElementById('upload-progress').classList.remove('hidden');
        uploadBtn.disabled = true;
        uploadBtn.textContent = 'Analyzing...';
        let pct = 0;
        const interval = setInterval(() => {
            pct = Math.min(pct + Math.random() * 15, 90);
            document.getElementById('upload-bar').style.width = pct + '%';
            document.getElementById('upload-pct').textContent = Math.round(pct) + '%';
            if (pct >= 90) clearInterval(interval);
        }, 300);
  });
})();
</script>
</body>
</html>
