<!DOCTYPE html>
<html lang="en">
<%- include('../layout/_head', { title: 'User Data Scopes' }) %>
<body class="bg-brand-dark text-gray-100 font-sans antialiased">
<%- include('../layout/_sidebar', { page: 'settings', user }) %>
<div id="main-wrapper" class="flex flex-col min-h-screen">
<%- include('../layout/_header', { breadcrumbs: ['Settings', 'User Data Scopes'], user }) %>
<main class="flex-1 p-6 overflow-y-auto">
  <% const flash_success = locals.messages?.success?.[0] || ''; %>
  <% const flash_error   = locals.messages?.error?.[0]   || ''; %>
  <% if (flash_success) { %><div class="mb-4 p-3 bg-green-500/10 border border-green-500/30 rounded-lg text-sm text-green-400"><i class="fa-solid fa-check mr-2"></i><%- flash_success %></div><% } %>
  <% if (flash_error)   { %><div class="mb-4 p-3 bg-red-500/10 border border-red-500/30 rounded-lg text-sm text-red-400"><i class="fa-solid fa-triangle-exclamation mr-2"></i><%- flash_error %></div><% } %>

  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold">User Data Scopes</h1>
      <p class="text-brand-textMuted text-sm mt-1">Control which contacts each user can access (row-level security)</p>
    </div>
    <a href="/settings" class="text-sm text-brand-textMuted hover:text-white">← Settings</a>
  </div>

  <div class="space-y-4">
    <% for (const m of members) { %>
    <div class="bg-brand-card border border-brand-border rounded-xl overflow-hidden">
      <div class="px-5 py-3 border-b border-brand-border flex items-center gap-4">
        <div class="w-7 h-7 rounded-full bg-brand-primary/20 text-brand-primary flex items-center justify-center text-xs font-bold shrink-0">
          <%= (m.name || '?').slice(0,2).toUpperCase() %>
        </div>
        <div>
          <div class="font-medium text-sm"><%= m.name %></div>
          <div class="text-xs text-brand-textMuted"><%= m.email %> &nbsp;·&nbsp; <%= m.role %></div>
        </div>
        <div class="ml-auto">
          <span class="text-xs px-2 py-1 rounded bg-brand-primary/10 text-brand-primary">
            Current: <%= m.scope_type || 'all' %>
          </span>
        </div>
      </div>
      <form method="POST" action="/settings/user-scopes/<%= m.id %>" class="p-4 flex flex-wrap items-end gap-4">
        <div>
          <label class="block text-xs text-brand-textMuted mb-1">Scope Type</label>
          <select name="scope_type" onchange="toggleSegmentSelect(this)"
            class="bg-brand-sidebar border border-brand-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-brand-primary">
            <% for (const s of ['all','segment','imported_by_me','assigned']) { %>
            <option value="<%= s %>" <%= (m.scope_type || 'all') === s ? 'selected' : '' %>><%= s.replace('_',' ') %></option>
            <% } %>
          </select>
        </div>
        <div class="segment-select" style="display:<%= m.scope_type === 'segment' ? 'block' : 'none' %>">
          <label class="block text-xs text-brand-textMuted mb-1">Segment</label>
          <select name="segment_id" class="bg-brand-sidebar border border-brand-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-brand-primary">
            <option value="">— select segment —</option>
            <% for (const seg of segments) { %>
            <option value="<%= seg.id %>" <%= m.segment_id === seg.id ? 'selected' : '' %>><%= seg.name %></option>
            <% } %>
          </select>
        </div>
        <button type="submit" class="px-4 py-2 bg-brand-primary/20 border border-brand-primary/50 text-brand-primary hover:bg-brand-primary hover:text-white rounded-lg text-sm transition">
          Save Scope
        </button>
      </form>
    </div>
    <% } %>
  </div>
</main>
</div>

<script>
function toggleSegmentSelect(sel) {
  const wrap = sel.closest('form').querySelector('.segment-select');
  wrap.style.display = sel.value === 'segment' ? 'block' : 'none';
}
</script>
</body></html>
