<!DOCTYPE html>
<html lang="en">
<%- include('../layout/_head', { title: 'AI Enrichment Progress' }) %>
<body class="bg-brand-dark text-gray-100 font-sans antialiased">
<%- include('../layout/_sidebar', { page: 'contacts', user }) %>
<div id="main-wrapper" class="flex flex-col min-h-screen">
<%- include('../layout/_header', { breadcrumbs, user }) %>
<main class="flex-1 overflow-y-auto p-6">

<div class="max-w-2xl mx-auto space-y-6">
  <!-- Header -->
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-xl font-semibold flex items-center gap-2">
        <i class="fa-solid fa-wand-magic-sparkles text-purple-400"></i>
        AI Contact Enrichment
      </h1>
      <p class="text-sm text-brand-textMuted mt-1">
        Job <%= job.job_type %> · <%= job.total %> contact<%= job.total !== 1 ? 's' : '' %> ·
        Started <%= new Date(job.created_at).toLocaleString('en-IN', {day:'2-digit',month:'short',hour:'2-digit',minute:'2-digit'}) %>
      </p>
    </div>
    <a href="/contacts" class="text-sm text-brand-textMuted hover:text-white transition-colors"><i class="fa-solid fa-arrow-left mr-1.5"></i>Contacts</a>
  </div>

  <!-- Circular progress -->
  <div class="bg-brand-card border border-brand-border rounded-2xl p-8 text-center">
    <div class="relative inline-flex items-center justify-center mb-4">
      <svg width="140" height="140" class="-rotate-90">
        <circle cx="70" cy="70" r="56" fill="none" stroke="#2a3347" stroke-width="10"/>
        <circle id="progress-circle" cx="70" cy="70" r="56" fill="none"
          stroke="#7c3aed" stroke-width="10" stroke-linecap="round"
          stroke-dasharray="351.86" stroke-dashoffset="351.86"
          style="transition: stroke-dashoffset 0.8s ease;"/>
      </svg>
      <div class="absolute flex flex-col items-center">
        <span id="pct-text" class="text-3xl font-black text-white">0%</span>
        <span class="text-xs text-brand-textMuted">complete</span>
      </div>
    </div>

    <!-- Stats row -->
    <div class="grid grid-cols-4 gap-3 mt-2">
      <div class="bg-brand-dark rounded-xl p-3">
        <p class="text-xl font-bold text-white" id="s-total"><%= job.total %></p>
        <p class="text-[10px] text-brand-textMuted mt-0.5">Total</p>
      </div>
      <div class="bg-brand-dark rounded-xl p-3">
        <p class="text-xl font-bold text-green-400" id="s-done">0</p>
        <p class="text-[10px] text-brand-textMuted mt-0.5">Done</p>
      </div>
      <div class="bg-brand-dark rounded-xl p-3">
        <p class="text-xl font-bold text-red-400" id="s-failed">0</p>
        <p class="text-[10px] text-brand-textMuted mt-0.5">Failed</p>
      </div>
      <div class="bg-brand-dark rounded-xl p-3">
        <p class="text-xl font-bold text-amber-400" id="s-remaining"><%= job.total %></p>
        <p class="text-[10px] text-brand-textMuted mt-0.5">Remaining</p>
      </div>
    </div>
  </div>

  <!-- Status card -->
  <div id="status-card" class="bg-brand-card border border-purple-500/30 rounded-xl p-4 flex items-center gap-3">
    <span class="w-2.5 h-2.5 rounded-full bg-purple-500 animate-pulse shrink-0"></span>
    <div>
      <p class="text-sm font-medium" id="status-text">Enrichment running…</p>
      <p class="text-xs text-brand-textMuted mt-0.5" id="status-sub">Claude is researching contacts using public web data</p>
    </div>
  </div>

  <!-- ETA -->
  <div id="eta-row" class="bg-brand-card border border-brand-border rounded-xl px-5 py-3 flex items-center justify-between text-xs">
    <span class="text-brand-textMuted">Estimated time remaining</span>
    <span id="eta-text" class="text-white font-medium">calculating…</span>
  </div>

  <!-- Actions -->
  <div class="flex gap-3">
    <a href="/contacts?enriched=true" class="flex-1 py-2.5 text-center bg-brand-primary text-white rounded-lg text-sm font-semibold hover:bg-blue-500 transition-all">
      <i class="fa-solid fa-users mr-2"></i>View Enriched Contacts
    </a>
    <a href="/contacts" class="px-5 py-2.5 bg-btnSecondary border border-btnBorder rounded-lg text-sm hover:bg-brand-border/50 transition-all">
      Back
    </a>
  </div>
</div>

</main>
</div>
<div id="toast-container"></div>
<script>
const JOB_ID    = '<%= job.id %>';
const JOB_TOTAL = <%= job.total %>;
const CIRCUMFERENCE = 351.86;
const startTime = Date.now();
let lastCompleted = 0;

function updateUI(data) {
  const { total, completed, failed, pct, status } = data;
  const remaining = Math.max(0, total - completed - failed);

  // Circle
  const offset = CIRCUMFERENCE - (pct / 100) * CIRCUMFERENCE;
  document.getElementById('progress-circle').style.strokeDashoffset = offset;
  document.getElementById('pct-text').textContent = pct + '%';

  // Stats
  document.getElementById('s-done').textContent      = completed;
  document.getElementById('s-failed').textContent    = failed;
  document.getElementById('s-remaining').textContent = remaining;

  // ETA
  const elapsed = (Date.now() - startTime) / 1000;
  if (completed > 0 && remaining > 0) {
    const rate    = completed / elapsed; // contacts per second
    const etaSec  = Math.round(remaining / rate);
    const etaMin  = Math.floor(etaSec / 60);
    const etaSecs = etaSec % 60;
    document.getElementById('eta-text').textContent = etaMin > 0 ? `~${etaMin}m ${etaSecs}s` : `~${etaSecs}s`;
  }

  // Status card
  if (status === 'completed') {
    document.getElementById('status-card').className = 'bg-green-500/10 border border-green-500/30 rounded-xl p-4 flex items-center gap-3';
    document.getElementById('status-text').textContent = 'Enrichment complete!';
    document.getElementById('status-sub').textContent  = `${completed} contacts enriched · ${failed} failed`;
    document.querySelector('#status-card span').className = 'w-2.5 h-2.5 rounded-full bg-green-500 shrink-0';
    document.getElementById('eta-row').style.display = 'none';
    window.toastSuccess && toastSuccess('All enrichment jobs finished!');
  } else if (status === 'failed') {
    document.getElementById('status-card').className = 'bg-red-500/10 border border-red-500/30 rounded-xl p-4 flex items-center gap-3';
    document.getElementById('status-text').textContent = 'Enrichment failed';
    document.querySelector('#status-card span').className = 'w-2.5 h-2.5 rounded-full bg-red-500 shrink-0';
  }
}

// SSE
const es = new EventSource(`/enrichment/job/${JOB_ID}/progress`);
es.onmessage = (ev) => {
  try {
    const data = JSON.parse(ev.data);
    if (data.error) return;
    updateUI(data);
    if (data.status === 'completed' || data.status === 'failed') es.close();
  } catch {}
};
es.onerror = () => {
  document.getElementById('status-sub').textContent = 'Polling paused — refreshing…';
  es.close();
  setTimeout(() => window.location.reload(), 5000);
};
</script>
</body>
</html>
