<!DOCTYPE html>
<html lang="en">
<%- include('../../layout/_head', { title: 'WhatsApp Numbers' }) %>
<body class="bg-brand-dark text-gray-100 font-sans antialiased">
<%- include('../../layout/_sidebar', { page: 'whatsapp', user }) %>
<div id="main-wrapper" class="flex flex-col min-h-screen">
<%- include('../../layout/_header', { breadcrumbs, user }) %>
<main class="flex-1 p-6 overflow-y-auto">

<!-- Header -->
<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-white">WhatsApp Numbers</h1>
    <p class="text-brand-textMuted text-sm mt-1">Manage your WABA phone numbers and quality scores</p>
  </div>
  <button onclick="openAddPhone()" class="px-4 py-2 bg-brand-primary text-white rounded-lg text-sm font-semibold hover:bg-purple-500 transition-all flex items-center gap-2">
    <i class="fa-solid fa-plus"></i>Add Phone Number
  </button>
</div>

<!-- Quality legend -->
<div class="flex items-center gap-4 mb-6 text-xs">
  <span class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-green-500 inline-block"></span>GREEN — Healthy</span>
  <span class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-yellow-400 inline-block animate-pulse"></span>YELLOW — Auto-paused, review required</span>
  <span class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-red-500 inline-block"></span>RED — Stopped, manual review required</span>
</div>

<!-- Phone cards -->
<% if (phones.length === 0) { %>
<div class="bg-brand-card border border-brand-border rounded-xl p-16 text-center">
  <i class="fa-brands fa-whatsapp text-5xl text-green-500 mb-4"></i>
  <h3 class="text-lg font-semibold text-white mb-2">No phone numbers yet</h3>
  <p class="text-brand-textMuted text-sm mb-6">Add a WABA phone number to start sending WhatsApp campaigns.</p>
  <button onclick="openAddPhone()" class="px-5 py-2.5 bg-brand-primary text-white rounded-lg text-sm font-semibold">Add Phone Number</button>
</div>
<% } else { %>
<div class="grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-3 gap-4">
<% phones.forEach(p => {
  const qColor = p.quality_score === 'GREEN' ? 'text-green-400 bg-green-400/10'
               : p.quality_score === 'YELLOW' ? 'text-yellow-400 bg-yellow-400/10'
               : 'text-red-400 bg-red-400/10';
  const tierLabel = { 1:'Tier 1', 2:'Tier 2', 3:'Tier 3', 4:'Unlimited' }[p.tier] || 'Tier 1';
  const pct = Math.min(100, Math.round((p.messages_sent_today / (p.daily_limit || 1)) * 100));
%>
<div class="bg-brand-card border border-brand-border rounded-xl p-5 flex flex-col gap-4">
  <div class="flex items-start justify-between">
    <div>
      <div class="flex items-center gap-2">
        <i class="fa-brands fa-whatsapp text-green-400 text-lg"></i>
        <span class="font-semibold text-white"><%= p.display_name %></span>
      </div>
      <p class="text-brand-textMuted text-sm mt-0.5"><%= p.phone_number %></p>
    </div>
    <div class="flex flex-col items-end gap-1.5">
      <span class="px-2 py-0.5 rounded-full text-xs font-semibold <%= qColor %> <%= p.quality_score==='YELLOW'?'animate-pulse':'' %>">
        ● <%= p.quality_score %>
      </span>
      <span class="px-2 py-0.5 bg-brand-border/40 text-brand-textMuted text-[10px] rounded font-medium"><%= tierLabel %></span>
    </div>
  </div>

  <% if (p.is_paused) { %>
  <div class="flex items-start gap-2 p-3 bg-yellow-400/10 border border-yellow-400/20 rounded-lg text-xs text-yellow-300">
    <i class="fa-solid fa-triangle-exclamation mt-0.5"></i>
    <span>Paused: <%= p.pause_reason || 'Unknown reason' %></span>
  </div>
  <% } %>

  <!-- Daily usage bar -->
  <div>
    <div class="flex justify-between text-xs text-brand-textMuted mb-1.5">
      <span>Today's usage</span>
      <span><%= (p.messages_sent_today||0).toLocaleString() %> / <%= (p.daily_limit||1000).toLocaleString() %></span>
    </div>
    <div class="h-1.5 bg-brand-border rounded-full overflow-hidden">
      <div class="h-full rounded-full <%= pct>80?'bg-red-500':pct>60?'bg-yellow-400':'bg-green-500' %> transition-all" style="width:<%= pct %>%"></div>
    </div>
  </div>

  <div class="flex items-center gap-2 pt-1 border-t border-brand-border/50">
    <a href="/whatsapp/campaigns?phone=<%= p.id %>" class="flex-1 text-center py-1.5 text-xs bg-brand-sidebar border border-brand-border rounded-lg hover:border-brand-primary/50 transition-all text-brand-textMuted hover:text-white">
      <i class="fa-solid fa-paper-plane mr-1"></i>Campaigns
    </a>
    <button onclick="refreshQuality('<%= p.id %>')" class="py-1.5 px-3 text-xs bg-brand-sidebar border border-brand-border rounded-lg hover:border-brand-primary/50 transition-all text-brand-textMuted hover:text-white" title="Refresh quality score">
      <i class="fa-solid fa-rotate-right"></i>
    </button>
    <button type="button" onclick="editPhone('<%= p.id %>')" class="py-1.5 px-3 text-xs bg-brand-sidebar border border-brand-border rounded-lg hover:border-brand-primary/50 transition-all text-brand-textMuted hover:text-white">
      <i class="fa-solid fa-pen"></i>
    </button>
  </div>
</div>
<% }) %>
</div>
<% } %>

<!-- Add Phone Modal -->
<div id="add-phone-modal" class="fixed inset-0 bg-black/60 z-50 hidden items-center justify-center">
  <div class="bg-brand-card border border-brand-border rounded-2xl p-6 w-full max-w-lg mx-4">
    <div class="flex items-center justify-between mb-5">
      <h2 id="phone-modal-title" class="font-bold text-white text-lg"><i class="fa-brands fa-whatsapp text-green-400 mr-2"></i>Add WABA Phone Number</h2>
      <button type="button" onclick="closeAddPhone()" class="text-brand-textMuted hover:text-white"><i class="fa-solid fa-xmark text-lg"></i></button>
    </div>
    <form id="add-phone-form" class="space-y-4">
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="block text-xs text-brand-textMuted mb-1.5">Display Name *</label>
          <input name="display_name" required class="w-full bg-brand-sidebar border border-brand-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-brand-primary" placeholder="My Business Number">
        </div>
        <div>
          <label class="block text-xs text-brand-textMuted mb-1.5">Phone Number (E.164) *</label>
          <input name="phone_number" required class="w-full bg-brand-sidebar border border-brand-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-brand-primary" placeholder="+919876543210">
        </div>
      </div>
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="block text-xs text-brand-textMuted mb-1.5">Phone Number ID (Meta) *</label>
          <input name="phone_number_id" required class="w-full bg-brand-sidebar border border-brand-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-brand-primary" placeholder="1234567890">
        </div>
        <div>
          <label class="block text-xs text-brand-textMuted mb-1.5">WABA ID *</label>
          <input name="waba_id" required class="w-full bg-brand-sidebar border border-brand-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-brand-primary" placeholder="9876543210">
        </div>
      </div>
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="block text-xs text-brand-textMuted mb-1.5">BSP *</label>
          <select name="bsp" required class="w-full bg-brand-sidebar border border-brand-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-brand-primary">
            <option value="meta_cloud">Meta Cloud API</option>
            <option value="360dialog">360dialog</option>
            <option value="twilio">Twilio</option>
          </select>
        </div>
        <div>
          <label class="block text-xs text-brand-textMuted mb-1.5">Tier</label>
          <select name="tier" class="w-full bg-brand-sidebar border border-brand-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-brand-primary">
            <option value="1">Tier 1 — 1,000/day</option>
            <option value="2">Tier 2 — 10,000/day</option>
            <option value="3">Tier 3 — 100,000/day</option>
            <option value="4">Unlimited</option>
          </select>
        </div>
      </div>
      <div>
        <label class="block text-xs text-brand-textMuted mb-1.5">Access Token (Meta)</label>
        <input name="access_token" type="password" class="w-full bg-brand-sidebar border border-brand-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-brand-primary" placeholder="EAAxxxxx...">
      </div>
      <div>
        <label class="block text-xs text-brand-textMuted mb-1.5">BSP API Key (360dialog)</label>
        <input name="bsp_api_key" type="password" class="w-full bg-brand-sidebar border border-brand-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-brand-primary" placeholder="Only for 360dialog">
      </div>
      <div class="flex gap-2 pt-2">
        <button type="button" onclick="closeAddPhone()" class="flex-1 py-2 bg-brand-sidebar border border-brand-border rounded-lg text-sm hover:border-brand-border/80">Cancel</button>
        <button type="submit" id="phone-modal-submit" class="flex-1 py-2 bg-brand-primary text-white rounded-lg text-sm font-semibold hover:bg-purple-500">Add Number</button>
      </div>
    </form>
  </div>
</div>

</main>
</div>
<div id="toast-container"></div>
<script>
const WA_PHONES = <%- JSON.stringify((phones || []).map(p => ({
  id: p.id,
  display_name: p.display_name,
  phone_number: p.phone_number,
  phone_number_id: p.phone_number_id,
  waba_id: p.waba_id,
  bsp: p.bsp,
  tier: p.tier,
}))) %>;

let editingPhoneId = null;

function openAddPhone() {
  editingPhoneId = null;
  document.getElementById('phone-modal-title').innerHTML = '<i class="fa-brands fa-whatsapp text-green-400 mr-2"></i>Add WABA Phone Number';
  document.getElementById('phone-modal-submit').textContent = 'Add Number';
  const f = document.getElementById('add-phone-form');
  f.reset();
  f.access_token.placeholder = 'EAAxxxxx...';
  f.bsp_api_key.placeholder = 'Only for 360dialog';
  document.getElementById('add-phone-modal').classList.replace('hidden','flex');
}

function closeAddPhone() {
  document.getElementById('add-phone-modal').classList.replace('flex','hidden');
  editingPhoneId = null;
}

function editPhone(id) {
  const p = WA_PHONES.find((x) => x.id === id);
  if (!p) { toastError('Phone record not found'); return; }
  editingPhoneId = id;
  document.getElementById('phone-modal-title').innerHTML = '<i class="fa-brands fa-whatsapp text-green-400 mr-2"></i>Edit WABA Phone Number';
  document.getElementById('phone-modal-submit').textContent = 'Save changes';
  const f = document.getElementById('add-phone-form');
  f.reset();
  f.display_name.value = p.display_name || '';
  f.phone_number.value = p.phone_number || '';
  f.phone_number_id.value = p.phone_number_id || '';
  f.waba_id.value = p.waba_id || '';
  f.bsp.value = p.bsp || 'meta_cloud';
  f.tier.value = String(p.tier || 1);
  f.access_token.value = '';
  f.bsp_api_key.value = '';
  f.access_token.placeholder = 'Leave blank to keep current token';
  f.bsp_api_key.placeholder = 'Leave blank to keep current key';
  document.getElementById('add-phone-modal').classList.replace('hidden','flex');
}

document.getElementById('add-phone-form').addEventListener('submit', async function(e) {
  e.preventDefault();
  const data = Object.fromEntries(new FormData(this));
  const isEdit = !!editingPhoneId;
  const url = isEdit ? `/whatsapp/phones/${editingPhoneId}` : '/whatsapp/phones';
  const method = isEdit ? 'PUT' : 'POST';
  const res = await fetch(url, { method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
  const j = await res.json();
  if (j.ok) {
    toastSuccess(isEdit ? 'Phone number updated' : 'Phone number added');
    closeAddPhone();
    setTimeout(() => location.reload(), 800);
  } else toastError(j.error || 'Request failed');
});

async function refreshQuality(id) {
  const res = await fetch(`/whatsapp/phones/${id}/quality`);
  const j = await res.json();
  if (j.quality_score) { toastInfo(`Quality score: ${j.quality_score}`); setTimeout(() => location.reload(), 1500); }
  else toastError(j.error || 'Failed');
}
</script>
</body>
</html>
