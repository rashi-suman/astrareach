<!DOCTYPE html>
<html lang="en">
<%- include('../../../layout/_head', { title: 'New WA Campaign — Step 2' }) %>
<body class="bg-brand-dark text-gray-100 font-sans antialiased">
<%- include('../../../layout/_sidebar', { page: 'whatsapp', user }) %>
<div id="main-wrapper" class="flex flex-col min-h-screen">
<%- include('../../../layout/_header', { breadcrumbs, user }) %>
<main class="flex-1 p-6">
<div class="max-w-3xl mx-auto">

  <%- include('./_stepper', { step: 2 }) %>

  <form action="/whatsapp/campaigns/new/step/2" method="POST" class="space-y-5 mt-6">
    <div class="bg-brand-card border border-brand-border rounded-xl p-6">
      <h2 class="font-bold text-white text-lg mb-4">Select Approved Template</h2>
      <% if (templates.length === 0) { %>
      <div class="p-4 bg-yellow-500/10 border border-yellow-500/20 rounded-lg text-sm text-yellow-300">
        <i class="fa-solid fa-triangle-exclamation mr-2"></i>No approved templates. <a href="/whatsapp/templates/new" class="underline">Create and submit one first</a>.
      </div>
      <% } else { %>
      <div class="space-y-3">
        <% templates.forEach(t => { %>
        <label class="flex items-start gap-4 p-4 border border-brand-border rounded-xl cursor-pointer hover:border-brand-primary/50 transition-all has-[:checked]:border-brand-primary has-[:checked]:bg-brand-primary/5">
          <input type="radio" name="template_id" value="<%= t.id %>" <%= draft.template_id===t.id.toString()?'checked':'' %> required class="mt-1">
          <div class="flex-1">
            <div class="flex items-center gap-2 mb-1">
              <span class="font-medium text-white text-sm"><%= t.name %></span>
              <span class="text-[10px] bg-green-500/10 text-green-400 border border-green-500/20 px-1.5 py-0.5 rounded">APPROVED</span>
              <span class="text-[10px] text-brand-textMuted"><%= t.category %> · <%= t.language %></span>
            </div>
            <p class="text-brand-textMuted text-xs line-clamp-2"><%= t.body_text %></p>
            <% if (t.variables && t.variables.length > 0) { %>
            <div class="flex gap-1 mt-2 flex-wrap">
              <% t.variables.forEach(v => { %><span class="text-[10px] bg-brand-primary/10 text-brand-secondary px-1.5 py-0.5 rounded">{{<%= v %>}}</span><% }) %>
            </div>
            <% } %>
          </div>
        </label>
        <% }) %>
      </div>
      <% } %>
    </div>

    <div class="flex justify-between">
      <a href="/whatsapp/campaigns/new/step/1" class="px-5 py-2.5 bg-brand-sidebar border border-brand-border rounded-lg text-sm hover:border-brand-border/80">← Back</a>
      <button type="submit" class="px-6 py-2.5 bg-brand-primary text-white rounded-lg text-sm font-semibold hover:bg-purple-500">Next →</button>
    </div>
  </form>
</div>
</main>
</div>
<div id="toast-container"></div>
</body>
</html>
