<!DOCTYPE html>
<html lang="en">
<%- include('../../../layout/_head', { title: 'New WA Campaign — Step 1' }) %>
<body class="bg-brand-dark text-gray-100 font-sans antialiased">
<%- include('../../../layout/_sidebar', { page: 'whatsapp', user }) %>
<div id="main-wrapper" class="flex flex-col min-h-screen">
<%- include('../../../layout/_header', { breadcrumbs, user }) %>
<main class="flex-1 p-6">
<div class="max-w-2xl mx-auto">

  <!-- Stepper -->
  <%- include('./_stepper', { step: 1 }) %>

  <form action="/whatsapp/campaigns/new/step/1" method="POST" class="space-y-5 mt-6">
    <div class="bg-brand-card border border-brand-border rounded-xl p-6 space-y-5">
      <h2 class="font-bold text-white text-lg">Campaign Details</h2>
      <div>
        <label class="block text-sm text-brand-textMuted mb-1.5">Campaign Name *</label>
        <input name="name" value="<%= draft.name||'' %>" required class="w-full bg-brand-sidebar border border-brand-border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:border-brand-primary" placeholder="Q2 Outreach — High Intent">
      </div>
      <div>
        <label class="block text-sm text-brand-textMuted mb-1.5">Description</label>
        <textarea name="description" rows="2" class="w-full bg-brand-sidebar border border-brand-border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:border-brand-primary resize-none" placeholder="Optional description"><%= draft.description||'' %></textarea>
      </div>
      <div>
        <label class="block text-sm text-brand-textMuted mb-1.5">WhatsApp Phone Number *</label>
        <% if (phones.length === 0) { %>
        <div class="p-3 bg-yellow-500/10 border border-yellow-500/20 rounded-lg text-sm text-yellow-300">
          <i class="fa-solid fa-triangle-exclamation mr-2"></i>No active phone numbers. <a href="/whatsapp/phones" class="underline">Add one first</a>.
        </div>
        <% } else { %>
        <select name="phone_number_id" required class="w-full bg-brand-sidebar border border-brand-border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:border-brand-primary">
          <option value="">— Select —</option>
          <% phones.forEach(p => { %>
          <option value="<%= p.id %>" <%= draft.phone_number_id===p.id.toString()?'selected':'' %>>
            <%= p.display_name %> — <%= p.phone_number %> (Tier <%= p.tier %>, <%= p.daily_limit.toLocaleString() %>/day) <% if(p.quality_score!=='GREEN'){%>[<%= p.quality_score %>]<%}%>
          </option>
          <% }) %>
        </select>
        <% } %>
      </div>
    </div>
    <div class="flex justify-between">
      <a href="/whatsapp/campaigns" class="px-5 py-2.5 bg-brand-sidebar border border-brand-border rounded-lg text-sm hover:border-brand-border/80">Cancel</a>
      <button type="submit" class="px-6 py-2.5 bg-brand-primary text-white rounded-lg text-sm font-semibold hover:bg-purple-500">Next →</button>
    </div>
  </form>
</div>
</main>
</div>
<div id="toast-container"></div>
</body>
</html>
