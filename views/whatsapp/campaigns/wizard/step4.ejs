<!DOCTYPE html>
<html lang="en">
<%- include('../../../layout/_head', { title: 'New WA Campaign — Step 4' }) %>
<body class="bg-brand-dark text-gray-100 font-sans antialiased">
<%- include('../../../layout/_sidebar', { page: 'whatsapp', user }) %>
<div id="main-wrapper" class="flex flex-col min-h-screen">
<%- include('../../../layout/_header', { breadcrumbs, user }) %>
<main class="flex-1 p-6">
<div class="max-w-2xl mx-auto">

  <%- include('./_stepper', { step: 4 }) %>

  <% const selTemplate = templates.find(t => t.id === draft.template_id || t.id.toString() === draft.template_id); %>

  <form action="/whatsapp/campaigns/new/step/4" method="POST" class="space-y-5 mt-6">

    <!-- Variable mapping -->
    <% if (selTemplate && selTemplate.variables && selTemplate.variables.length > 0) { %>
    <div class="bg-brand-card border border-brand-border rounded-xl p-6 space-y-4">
      <h2 class="font-bold text-white text-lg">Variable Mapping</h2>
      <p class="text-brand-textMuted text-sm">Map each template variable to a contact field.</p>
      <% const crmFields = ['first_name','last_name','company','job_title','phone','email','city','country','website','industry']; %>
      <% selTemplate.variables.forEach((v, i) => { %>
      <div class="flex items-center gap-3">
        <span class="text-brand-secondary font-mono text-sm w-10">{{<%= i+1 %>}}</span>
        <select name="var_<%= i+1 %>" class="flex-1 bg-brand-sidebar border border-brand-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-brand-primary">
          <option value="">— Select field —</option>
          <% crmFields.forEach(f => { %><option value="<%= f %>"><%= f.replace(/_/g,' ') %></option><% }) %>
        </select>
      </div>
      <% }) %>
    </div>
    <% } %>

    <!-- Schedule & limits -->
    <div class="bg-brand-card border border-brand-border rounded-xl p-6 space-y-4">
      <h2 class="font-bold text-white text-lg">Schedule & Limits</h2>
      <% const waTz = draft.timezone || 'Asia/Kolkata'; %>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm text-brand-textMuted mb-1.5">Start date</label>
          <input name="schedule_date" type="date" value="<%= draft.schedule_date || new Date().toISOString().slice(0,10) %>" class="w-full bg-brand-sidebar border border-brand-border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:border-brand-primary">
          <p class="text-[10px] text-brand-textMuted mt-1">First eligible send (after you press Start). Respects daily limit below.</p>
        </div>
        <div>
          <label class="block text-sm text-brand-textMuted mb-1.5">Send time (local)</label>
          <input name="send_time" type="time" value="<%= draft.send_time||'10:00' %>" class="w-full bg-brand-sidebar border border-brand-border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:border-brand-primary">
        </div>
      </div>
      <div>
        <label class="block text-sm text-brand-textMuted mb-1.5">Timezone</label>
        <select name="timezone" class="w-full bg-brand-sidebar border border-brand-border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:border-brand-primary">
          <option value="Asia/Kolkata" <%= waTz === 'Asia/Kolkata' ? 'selected' : '' %>>IST (Asia/Kolkata)</option>
          <option value="UTC" <%= waTz === 'UTC' ? 'selected' : '' %>>UTC</option>
          <option value="America/New_York" <%= waTz === 'America/New_York' ? 'selected' : '' %>>EST (New York)</option>
        </select>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm text-brand-textMuted mb-1.5">Daily Limit</label>
          <input name="daily_limit" type="number" value="<%= draft.daily_limit||1000 %>" min="1" max="100000" class="w-full bg-brand-sidebar border border-brand-border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:border-brand-primary">
        </div>
        <div>
          <label class="block text-sm text-brand-textMuted mb-1.5">Messages/Second</label>
          <select name="messages_per_second" class="w-full bg-brand-sidebar border border-brand-border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:border-brand-primary">
            <% const mps = String(draft.messages_per_second || '1'); %>
            <option value="1" <%= mps === '1' ? 'selected' : '' %>>1/sec (Tier 1)</option>
            <option value="3" <%= mps === '3' ? 'selected' : '' %>>3/sec (Tier 2)</option>
            <option value="10" <%= mps === '10' ? 'selected' : '' %>>10/sec (Tier 3)</option>
          </select>
        </div>
      </div>
    </div>

    <!-- Review summary -->
    <div class="bg-brand-card border border-brand-border rounded-xl p-6">
      <h2 class="font-bold text-white text-lg mb-4">Review</h2>
      <div class="grid grid-cols-2 gap-3 text-sm">
        <div class="text-brand-textMuted">Campaign Name</div><div class="text-white font-medium"><%= draft.name %></div>
        <div class="text-brand-textMuted">Template</div><div class="text-white font-medium"><%= selTemplate?.name || '—' %></div>
        <div class="text-brand-textMuted">Segment</div><div class="text-white font-medium"><%= draft.segment_id ? (segments.find(s=>s.id===draft.segment_id||s.id.toString()===draft.segment_id)?.name||draft.segment_id) : 'All opted-in contacts' %></div>
      </div>
      <div class="mt-4 p-3 bg-green-500/10 border border-green-500/20 rounded-lg text-xs text-green-300">
        <i class="fa-solid fa-shield-check mr-2"></i>
        The system will automatically skip contacts without WhatsApp opt-in and enforce your phone number's daily tier limits.
      </div>
    </div>

    <div class="flex justify-between">
      <a href="/whatsapp/campaigns/new/step/3" class="px-5 py-2.5 bg-brand-sidebar border border-brand-border rounded-lg text-sm hover:border-brand-border/80">← Back</a>
      <button type="submit" class="px-6 py-2.5 bg-green-600 text-white rounded-lg text-sm font-semibold hover:bg-green-500">
        <i class="fa-brands fa-whatsapp mr-2"></i>Create Campaign
      </button>
    </div>
  </form>
</div>
</main>
</div>
<div id="toast-container"></div>
</body>
</html>
