<!DOCTYPE html>
<html lang="en">
<%- include('../../layout/_head', { title: 'WA Templates' }) %>
<body class="bg-brand-dark text-gray-100 font-sans antialiased">
<%- include('../../layout/_sidebar', { page: 'whatsapp', user }) %>
<div id="main-wrapper" class="flex flex-col" style="height:100vh;overflow:hidden;">
<%- include('../../layout/_header', { breadcrumbs, user }) %>

<!-- Fixed header bar -->
<div class="shrink-0 px-6 py-4 border-b border-brand-border bg-brand-dark">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-xl font-bold text-white">WA Templates <span class="text-brand-textMuted text-sm font-normal ml-2"><%= total %> total</span></h1>
    </div>
    <div class="flex items-center gap-3 flex-wrap">
      <% const syncPhones = (phones || []).filter(p => ['meta_cloud','360dialog'].includes(p.bsp)); %>
      <% if (syncPhones.length) { %>
      <div class="flex items-center gap-2">
        <% if (syncPhones.length > 1) { %>
        <select id="sync-wa-phone" class="bg-brand-card border border-brand-border rounded-lg px-2 py-1.5 text-xs max-w-[200px]">
          <% syncPhones.forEach(p => { %>
          <option value="<%= p.id %>"><%= p.display_name %></option>
          <% }) %>
        </select>
        <% } %>
        <button type="button" onclick="syncTemplates()" class="px-3 py-2 bg-brand-sidebar border border-brand-border rounded-lg text-sm hover:border-brand-primary/50 text-brand-textMuted hover:text-white">
          <i class="fa-solid fa-rotate mr-1.5"></i>Sync from Meta
        </button>
      </div>
      <% } %>
      <form method="GET" class="flex items-center gap-2">
        <input name="q" value="<%= query %>" placeholder="Search templates…" class="bg-brand-card border border-brand-border rounded-lg px-3 py-1.5 text-sm w-52 focus:outline-none focus:border-brand-primary">
        <button type="submit" class="px-3 py-1.5 bg-brand-sidebar border border-brand-border rounded-lg text-sm hover:border-brand-primary/50">
          <i class="fa-solid fa-magnifying-glass text-brand-textMuted"></i>
        </button>
      </form>
      <a href="/whatsapp/templates/new" class="px-4 py-2 bg-brand-primary text-white rounded-lg text-sm font-semibold hover:bg-purple-500 flex items-center gap-2">
        <i class="fa-solid fa-plus"></i>New Template
      </a>
    </div>
  </div>
</div>

<!-- Scrollable cards -->
<div class="flex-1 overflow-y-auto p-6">
<% if (templates.length === 0) { %>
<div class="flex flex-col items-center justify-center h-64 text-center">
  <i class="fa-regular fa-rectangle-list text-4xl text-brand-border mb-3"></i>
  <p class="text-brand-textMuted">No templates found. <a href="/whatsapp/templates/new" class="text-brand-primary hover:underline">Create your first</a>.</p>
</div>
<% } else { %>
<div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
<% templates.forEach(t => {
  const sc = t.status === 'APPROVED' ? 'bg-green-500/10 text-green-400 border-green-500/20'
           : t.status === 'REJECTED' ? 'bg-red-500/10 text-red-400 border-red-500/20'
           : t.status === 'PAUSED'   ? 'bg-yellow-500/10 text-yellow-400 border-yellow-500/20'
           : 'bg-blue-500/10 text-blue-400 border-blue-500/20';
%>
<div class="bg-brand-card border border-brand-border rounded-xl p-5 hover:border-brand-primary/30 transition-all flex flex-col gap-3">
  <div class="flex items-start justify-between gap-2">
    <div class="flex-1 min-w-0">
      <p class="font-semibold text-white truncate"><%= t.name %></p>
      <div class="flex items-center gap-2 mt-1">
        <span class="text-[10px] text-brand-textMuted bg-brand-border/40 px-2 py-0.5 rounded"><%= t.category %></span>
        <span class="text-[10px] text-brand-textMuted"><%= t.language %></span>
      </div>
    </div>
    <span class="px-2 py-0.5 border rounded text-[11px] font-semibold shrink-0 <%= sc %>"><%= t.status %></span>
  </div>
  <p class="text-brand-textMuted text-xs line-clamp-3 bg-brand-sidebar/40 p-2 rounded"><%= t.body_text %></p>
  <% if (t.rejected_reason) { %>
  <p class="text-red-400/90 text-[10px] line-clamp-2" title="<%= t.rejected_reason %>"><%= t.rejected_reason %></p>
  <% } %>
  <% if (t.variables && t.variables.length > 0) { %>
  <div class="flex flex-wrap gap-1">
    <% t.variables.forEach(v => { %>
    <span class="text-[10px] bg-brand-primary/10 text-brand-secondary px-1.5 py-0.5 rounded">{{<%= v %>}}</span>
    <% }) %>
  </div>
  <% } %>
  <div class="flex gap-2 pt-1 border-t border-brand-border/40">
    <button onclick="previewTemplate('<%= encodeURIComponent(JSON.stringify({name:t.name,body_text:t.body_text,header_type:t.header_type,header_content:t.header_content,footer_text:t.footer_text,buttons:t.buttons||[]})) %>')"
      class="flex-1 py-1.5 text-xs bg-brand-sidebar border border-brand-border rounded-lg hover:border-brand-primary/50 text-brand-textMuted hover:text-white">
      <i class="fa-solid fa-eye mr-1"></i>Preview
    </button>
    <% if (['PENDING','REJECTED'].includes(t.status)) { %>
    <button onclick="deleteTpl('<%= t.id %>')" class="py-1.5 px-3 text-xs bg-red-500/10 border border-red-500/20 rounded-lg text-red-400 hover:bg-red-500/20">
      <i class="fa-solid fa-trash"></i>
    </button>
    <% } %>
  </div>
</div>
<% }) %>
</div>
<% } %>

<!-- Pagination -->
<% if (total > limit) { %>
<div class="flex items-center justify-between mt-6">
  <span class="text-xs text-brand-textMuted">Showing <%= ((pageNo-1)*limit)+1 %>–<%= Math.min(pageNo*limit,total) %> of <%= total %></span>
  <div class="flex gap-1">
    <% if (pageNo > 1) { %><a href="?page=<%= pageNo-1 %>&q=<%= query %>" class="px-3 py-1.5 text-xs bg-brand-card border border-brand-border rounded-lg hover:border-brand-primary/50">Prev</a><% } %>
    <% if (pageNo*limit < total) { %><a href="?page=<%= pageNo+1 %>&q=<%= query %>" class="px-3 py-1.5 text-xs bg-brand-card border border-brand-border rounded-lg hover:border-brand-primary/50">Next</a><% } %>
  </div>
</div>
<% } %>
</div>

<!-- Preview Drawer -->
<div id="preview-overlay" class="modal-overlay" onclick="closePreview()"></div>
<div id="preview-drawer" class="drawer">
  <div class="p-6">
    <div class="flex items-center justify-between mb-5">
      <h3 class="font-bold text-white">Template Preview</h3>
      <button onclick="closePreview()" class="text-brand-textMuted hover:text-white"><i class="fa-solid fa-xmark text-lg"></i></button>
    </div>
    <!-- WhatsApp bubble preview -->
    <div class="bg-[#0b141a] rounded-xl p-4 mb-5">
      <p class="text-[10px] text-gray-500 mb-3">WhatsApp preview</p>
      <div class="flex justify-end">
        <div id="wa-bubble" class="max-w-[280px] bg-[#005c4b] rounded-2xl rounded-tr-sm px-3 py-2 text-sm text-white leading-relaxed shadow-lg">
        </div>
      </div>
    </div>
    <div id="preview-meta" class="space-y-2 text-sm text-brand-textMuted"></div>
  </div>
</div>

</div>
<div id="toast-container"></div>
<script>
function previewTemplate(encoded) {
  const t = JSON.parse(decodeURIComponent(encoded));
  const bubble = document.getElementById('wa-bubble');
  let html = '';
  if (t.header_content && t.header_type === 'TEXT') html += `<p class="font-bold text-xs mb-1">${t.header_content}</p>`;
  if (t.header_type === 'IMAGE' && t.header_content) html += `<img src="${t.header_content}" class="rounded mb-1 w-full object-cover h-32">`;
  html += `<p>${(t.body_text||'').replace(/\{\{(\d+)\}\}/g,'<span class="bg-white/20 px-1 rounded">{{$1}}</span>').replace(/\n/g,'<br>')}</p>`;
  if (t.footer_text) html += `<p class="text-[10px] text-gray-300 mt-1">${t.footer_text}</p>`;
  html += `<div class="text-right text-[10px] text-gray-300 mt-1">✓✓</div>`;
  if (t.buttons && t.buttons.length) {
    html += `<div class="border-t border-white/20 mt-2 pt-2 space-y-1">`;
    t.buttons.forEach(b => { html += `<div class="text-center text-[12px] text-blue-300">${b.text||b.label||'Button'}</div>`; });
    html += `</div>`;
  }
  bubble.innerHTML = html;
  document.getElementById('preview-overlay').classList.add('open');
  document.getElementById('preview-drawer').classList.add('open');
}
function closePreview() {
  document.getElementById('preview-overlay').classList.remove('open');
  document.getElementById('preview-drawer').classList.remove('open');
}
async function syncTemplates() {
  const sel = document.getElementById('sync-wa-phone');
  const body = {};
  if (sel) body.wa_phone_id = sel.value;
  try {
    const res = await fetch('/whatsapp/templates/sync', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify(body),
    });
    const j = await res.json();
    if (!res.ok || !j.ok) { toastError(j.error || 'Sync failed'); return; }
    toastSuccess('Updated ' + (j.updated || 0) + ' template(s) from Meta.');
    setTimeout(() => location.reload(), 900);
  } catch (e) { toastError(e.message || 'Sync failed'); }
}

async function deleteTpl(id) {
  if (!confirm('Delete this template?')) return;
  const res = await fetch(`/whatsapp/templates/${id}`, { method:'DELETE' });
  const j = await res.json();
  if (j.ok) { toastSuccess('Template deleted'); setTimeout(() => location.reload(), 800); }
  else toastError(j.error);
}
</script>
</body>
</html>
