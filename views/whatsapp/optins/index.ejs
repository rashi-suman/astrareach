<!DOCTYPE html>
<html lang="en">
<%- include('../../layout/_head', { title: 'WA Opt-ins' }) %>
<body class="bg-brand-dark text-gray-100 font-sans antialiased">
<%- include('../../layout/_sidebar', { page: 'whatsapp', user }) %>
<div id="main-wrapper" class="flex flex-col" style="height:100vh;overflow:hidden;">
<%- include('../../layout/_header', { breadcrumbs, user }) %>

<div class="shrink-0 px-6 py-3 border-b border-brand-border bg-brand-sidebar/30 text-xs text-brand-textMuted space-y-2">
  <p><strong class="text-white/90">How this list fills:</strong> Contacts must have the <strong class="text-white/80">WhatsApp number</strong> field set (edit a contact or import CSV with that column). Then use <strong class="text-white/80">Import all with WhatsApp</strong> for everyone at once, or <strong class="text-white/80">Import from segment</strong> for a filtered subset. You can also use <strong class="text-white/80">Record opt-in</strong> on each contact’s profile.</p>
  <p class="text-[11px]">Segments are under <a href="/segments" class="text-brand-primary hover:underline">Segments</a> — they filter the same contacts you use for email and WhatsApp (not a separate “email-only” list).</p>
</div>

<div class="shrink-0 px-6 py-3 border-b border-brand-border bg-brand-dark flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 flex-wrap">
  <h1 class="text-xl font-bold text-white">WhatsApp Opt-ins <span class="text-brand-textMuted text-sm font-normal ml-2"><%= total %> total</span></h1>
  <div class="flex items-center gap-2 flex-wrap justify-end">
    <button type="button" onclick="runImportAllWa()" class="px-3 py-1.5 text-xs font-semibold rounded-lg bg-brand-card border border-green-500/40 text-green-400 hover:bg-green-500/10" title="Every contact in your org with WhatsApp number filled">
      <i class="fa-solid fa-users mr-1"></i>Import all with WhatsApp
    </button>
    <% if (segments && segments.length) { %>
    <button type="button" onclick="openImportModal()" class="px-3 py-1.5 text-xs font-semibold rounded-lg bg-green-600/90 text-white hover:bg-green-600 border border-green-500/30">
      <i class="fa-solid fa-file-import mr-1"></i>Import from segment
    </button>
    <% } else { %>
    <a href="/segments" class="px-3 py-1.5 text-xs font-semibold rounded-lg bg-brand-card border border-brand-border text-white hover:border-brand-primary/50 inline-flex items-center gap-1">
      <i class="fa-solid fa-layer-group"></i>New segment
    </a>
    <% } %>
    <% ['','opted_in','opted_out'].forEach(s => { %>
    <a href="?status=<%= s %>" class="px-3 py-1.5 text-xs rounded-lg border <%= filterStatus===s ? 'bg-brand-primary border-brand-primary text-white' : 'bg-brand-card border-brand-border text-brand-textMuted hover:border-brand-primary/50' %>">
      <%= s || 'All' %>
    </a>
    <% }) %>
  </div>
</div>

<div class="flex-1 overflow-y-auto">
<table class="w-full text-sm">
  <thead class="sticky top-0 bg-brand-sidebar/90 text-[10px] uppercase tracking-wider text-brand-textMuted border-b border-brand-border">
    <tr>
      <th class="px-5 py-3 text-left">Contact</th>
      <th class="px-4 py-3 text-left">Phone</th>
      <th class="px-4 py-3 text-center">Status</th>
      <th class="px-4 py-3 text-left">Source</th>
      <th class="px-4 py-3 text-left">Date</th>
      <th class="px-4 py-3 text-center">Actions</th>
    </tr>
  </thead>
  <tbody class="divide-y divide-brand-border/40">
  <% if (!optins.length) { %>
  <tr>
    <td colspan="6" class="px-6 py-16 text-center text-brand-textMuted text-sm">
      <p class="mb-2">No rows in the opt-in registry yet.</p>
      <p class="text-xs max-w-lg mx-auto">Registry rows appear after you import or record consent. <strong class="text-white/90">Import all with WhatsApp</strong> adds every contact that has <code class="text-[10px] bg-brand-sidebar px-1 rounded">whatsapp_phone</code> set. <% if (segments && segments.length) { %><strong class="text-white/90">Import from segment</strong> limits to a segment (create filters under <a href="/segments" class="text-brand-primary hover:underline">Segments</a>, including new <em>WhatsApp phone</em> / <em>WhatsApp opted in</em> rules).<% } else { %>Create a <a href="/segments" class="text-brand-primary hover:underline">segment</a> to target a subset, then use <strong class="text-white">Import from segment</strong>.<% } %> Set numbers on <a href="/contacts" class="text-brand-primary hover:underline">Contacts</a> → edit contact, or use <strong class="text-white/90">Record WhatsApp opt-in</strong> on a contact’s page.</p>
    </td>
  </tr>
  <% } else { %>
  <% optins.forEach(o => { %>
  <tr class="hover:bg-brand-sidebar/20">
    <td class="px-5 py-3.5">
      <p class="font-medium text-white"><%= o.first_name||'' %> <%= o.last_name||'' %></p>
      <p class="text-[10px] text-brand-textMuted"><%= o.email||'' %></p>
    </td>
    <td class="px-4 py-3.5 text-brand-textMuted font-mono text-xs"><%= o.phone_number %></td>
    <td class="px-4 py-3.5 text-center">
      <span class="px-2 py-0.5 rounded-full text-[11px] font-semibold <%= o.status==='opted_in'?'text-green-400 bg-green-400/10':'text-red-400 bg-red-400/10' %>">
        <%= o.status==='opted_in' ? 'Opted In' : 'Opted Out' %>
      </span>
    </td>
    <td class="px-4 py-3.5 text-brand-textMuted text-xs"><%= o.source||'—' %></td>
    <td class="px-4 py-3.5 text-brand-textMuted text-xs"><%= (o.opted_in_at || o.opted_out_at) ? new Date(o.opted_in_at || o.opted_out_at).toLocaleDateString('en-IN') : '—' %></td>
    <td class="px-4 py-3.5 text-center">
      <% if (o.contact_id) { %>
        <% if (o.status === 'opted_in') { %>
        <button onclick="optOut('<%= o.contact_id %>')" class="px-2 py-1 text-xs text-red-400 hover:text-red-300 border border-red-500/20 rounded">Opt out</button>
        <% } else { %>
        <button onclick="optIn('<%= o.contact_id %>')" class="px-2 py-1 text-xs text-green-400 hover:text-green-300 border border-green-500/20 rounded">Opt in</button>
        <% } %>
      <% } %>
    </td>
  </tr>
    <% }) %>
  <% } %>
  </tbody>
</table>
</div>

<!-- Pagination -->
<div class="shrink-0 px-6 py-3 border-t border-brand-border flex items-center justify-between">
  <span class="text-xs text-brand-textMuted">Showing <%= ((pageNo-1)*limit)+1 %>–<%= Math.min(pageNo*limit,total) %> of <%= total %></span>
  <div class="flex gap-1">
    <% if (pageNo > 1) { %><a href="?page=<%= pageNo-1 %>&status=<%= filterStatus %>" class="px-3 py-1.5 text-xs bg-brand-card border border-brand-border rounded-lg hover:border-brand-primary/50">Prev</a><% } %>
    <% if (pageNo*limit < total) { %><a href="?page=<%= pageNo+1 %>&status=<%= filterStatus %>" class="px-3 py-1.5 text-xs bg-brand-card border border-brand-border rounded-lg hover:border-brand-primary/50">Next</a><% } %>
  </div>
</div>

<div id="import-seg-modal" class="fixed inset-0 bg-black/60 z-50 hidden items-center justify-center">
  <div class="bg-brand-card border border-brand-border rounded-2xl p-6 w-full max-w-md mx-4">
    <div class="flex items-center justify-between mb-4">
      <h2 class="font-bold text-white">Import segment into opt-ins</h2>
      <button type="button" onclick="closeImportModal()" class="text-brand-textMuted hover:text-white"><i class="fa-solid fa-xmark text-lg"></i></button>
    </div>
    <% if (segments && segments.length) { %>
    <p class="text-xs text-brand-textMuted mb-4">Adds or updates <code class="text-[10px] bg-brand-sidebar px-1 rounded">wa_opt_ins</code> for every contact in the segment that has <code class="text-[10px] bg-brand-sidebar px-1 rounded">whatsapp_phone</code> set, and sets <code class="text-[10px] bg-brand-sidebar px-1 rounded">whatsapp_opted_in</code> on the contact.</p>
    <select id="import-segment-id" class="w-full bg-brand-sidebar border border-brand-border rounded-lg px-3 py-2 text-sm mb-4">
      <% segments.forEach(s => { %>
      <option value="<%= s.id %>"><%= s.name %> (<%= s.contact_count||0 %>)</option>
      <% }) %>
    </select>
    <div class="flex gap-2">
      <button type="button" onclick="closeImportModal()" class="flex-1 py-2 bg-brand-sidebar border border-brand-border rounded-lg text-sm">Cancel</button>
      <button type="button" onclick="runImportSegment()" class="flex-1 py-2 bg-green-600 text-white rounded-lg text-sm font-semibold hover:bg-green-500">Import</button>
    </div>
    <% } else { %>
    <p class="text-sm text-brand-textMuted mb-4">You do not have any segments yet. Segments are created under <strong class="text-white">Segments</strong> in the left sidebar (same place as for email campaigns).</p>
    <p class="text-xs text-brand-textMuted mb-4">Add or import contacts, give them a <strong class="text-white/90">WhatsApp phone</strong> field, build a segment that includes those contacts, then come back to this page — the import button will show in the header.</p>
    <div class="flex gap-2">
      <button type="button" onclick="closeImportModal()" class="flex-1 py-2 bg-brand-sidebar border border-brand-border rounded-lg text-sm">Close</button>
      <a href="/segments" class="flex-1 py-2 bg-brand-primary text-white rounded-lg text-sm font-semibold text-center hover:bg-purple-500 leading-[2.25rem]">Open Segments</a>
    </div>
    <% } %>
  </div>
</div>

</div>
<div id="toast-container"></div>
<script>
function openImportModal() {
  const el = document.getElementById('import-seg-modal');
  if (el) el.classList.replace('hidden','flex');
}
function closeImportModal() {
  const el = document.getElementById('import-seg-modal');
  if (el) el.classList.replace('flex','hidden');
}
async function runImportAllWa() {
  if (!confirm('Register opt-in for every contact in your workspace that has a WhatsApp number filled in? (Large lists may take a moment.)')) return;
  const res = await fetch('/whatsapp/optins/import-segment', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ import_all_with_whatsapp: true }),
  });
  const j = await res.json();
  if (!res.ok || !j.ok) { toastError(j.error || 'Import failed'); return; }
  toastSuccess(`Imported ${j.imported} row(s); updated ${j.contacts_updated} contact(s).`);
  setTimeout(() => location.reload(), 900);
}
async function runImportSegment() {
  const sel = document.getElementById('import-segment-id');
  if (!sel || !sel.value) { toastError('Choose a segment'); return; }
  const res = await fetch('/whatsapp/optins/import-segment', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ segment_id: sel.value }),
  });
  const j = await res.json();
  if (!res.ok || !j.ok) { toastError(j.error || 'Import failed'); return; }
  toastSuccess(`Imported ${j.imported} registry row(s); updated ${j.contacts_updated} contact(s).`);
  closeImportModal();
  setTimeout(() => location.reload(), 900);
}

async function optOut(id) {
  if (!confirm('Record opt-out for this contact?')) return;
  const r = await fetch(`/whatsapp/optins/${id}/optout`, { method:'POST' });
  const j = await r.json();
  j.ok ? (toastSuccess('Opt-out recorded'), setTimeout(() => location.reload(), 800)) : toastError(j.error);
}
async function optIn(id) {
  const r = await fetch(`/whatsapp/optins/${id}/optin`, { method:'POST' });
  const j = await r.json();
  j.ok ? (toastSuccess('Opt-in recorded'), setTimeout(() => location.reload(), 800)) : toastError(j.error);
}
</script>
</body>
</html>
