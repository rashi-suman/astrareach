<!DOCTYPE html>
<html lang="en">
<%- include('../layout/_head', { title: 'Invite User' }) %>
<body class="bg-brand-dark text-gray-100 font-sans antialiased">
<%- include('../layout/_sidebar', { page: 'settings', user }) %>
<div id="main-wrapper" class="flex flex-col min-h-screen">
<%- include('../layout/_header', { breadcrumbs: ['Users', 'Invite'], user }) %>
<main class="flex-1 p-6 overflow-y-auto">
  <div class="max-w-lg mx-auto">
    <h1 class="text-2xl font-bold mb-6">Invite Team Member</h1>
    <div class="bg-brand-card border border-brand-border rounded-xl p-6 space-y-4">
      <form method="POST" action="/users" class="space-y-4">
        <div>
          <label class="block text-sm font-medium mb-1.5">Full Name</label>
          <input type="text" name="name" required class="w-full bg-brand-sidebar border border-brand-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-brand-primary">
        </div>
        <div>
          <label class="block text-sm font-medium mb-1.5">Email Address</label>
          <input type="email" name="email" required class="w-full bg-brand-sidebar border border-brand-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-brand-primary">
        </div>
        <div>
          <label class="block text-sm font-medium mb-1.5">Role</label>
          <select name="role" class="w-full bg-brand-sidebar border border-brand-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-brand-primary">
            <option value="campaign_manager">Campaign Manager</option>
            <option value="lead_manager">Lead Manager</option>
            <option value="editor">Editor</option>
            <option value="admin">Admin</option>
            <option value="superadmin">Super Admin</option>
          </select>
          <div class="mt-2 space-y-1 text-xs text-brand-textMuted">
            <p><span class="font-semibold text-white">Campaign Manager</span> — campaigns &amp; templates only</p>
            <p><span class="font-semibold text-white">Lead Manager</span> — contacts &amp; segments (view/create/edit)</p>
            <p><span class="font-semibold text-white">Editor</span> — contacts, segments, templates, analytics (view/create/edit — <span class="text-amber-400">no delete</span>)</p>
            <p><span class="font-semibold text-white">Admin</span> — all features except permissions</p>
            <p><span class="font-semibold text-white">Super Admin</span> — full access + user &amp; permission management</p>
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium mb-1.5">Password</label>
          <input type="password" name="password" required minlength="8" class="w-full bg-brand-sidebar border border-brand-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-brand-primary">
        </div>
        <div class="flex gap-3 pt-2">
          <button type="submit" class="px-5 py-2 bg-brand-primary hover:opacity-90 rounded-lg text-sm font-medium transition">Create User</button>
          <a href="/users" class="px-5 py-2 bg-brand-sidebar border border-brand-border hover:border-brand-primary rounded-lg text-sm transition">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</main>
</div>
</body></html>
