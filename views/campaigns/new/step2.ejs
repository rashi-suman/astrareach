<!DOCTYPE html>
<html lang="en">
<%- include('../../layout/_head', { title: 'New Campaign - Step 2' }) %>
<body class="bg-brand-dark text-gray-100 font-sans antialiased">
<%- include('../../layout/_sidebar', { page: 'campaigns', user }) %>
<div id="main-wrapper" class="flex flex-col min-h-screen">
<%- include('../../layout/_header', { breadcrumbs, user }) %>
<main class="flex-1 overflow-y-auto p-6">
<div class="max-w-2xl mx-auto">

    <!-- Wizard Steps -->
    <div class="flex items-center gap-0 mb-8">
        <% [['1','Name'],['2','Audience'],['3','Template'],['4','Launch']].forEach(([num, label], i) => { %>
        <div class="flex items-center">
            <div class="flex items-center gap-2">
                <div class="w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold
                    <%= num === '2' ? 'bg-brand-primary text-white' : parseInt(num) < 2 ? 'bg-green-500 text-white' : 'bg-btnSecondary border border-btnBorder text-brand-textMuted' %>">
                    <% if (parseInt(num) < 2) { %><i class="fa-solid fa-check text-[10px]"></i><% } else { %><%= num %><% } %>
                </div>
                <span class="text-xs font-medium <%= num === '2' ? 'text-white' : parseInt(num) < 2 ? 'text-green-400' : 'text-brand-textMuted' %>"><%= label %></span>
            </div>
            <% if (i < 3) { %><div class="h-px w-10 sm:w-16 bg-brand-border mx-3"></div><% } %>
        </div>
        <% }) %>
    </div>

    <div class="bg-brand-card border border-brand-border rounded-xl p-6 space-y-6">
        <div>
            <h2 class="text-lg font-semibold">Select Audience</h2>
            <p class="text-xs text-brand-textMuted mt-1">Choose a saved segment, or search and pick individual contacts.</p>
        </div>

        <form action="/campaigns/new/step/2" method="POST" id="audience-form" class="space-y-6">

            <!-- Segment selector -->
            <div>
                <label class="block text-xs font-medium text-brand-textMuted uppercase tracking-wide mb-1.5">
                    <i class="fa-solid fa-layer-group mr-1"></i>Use a Saved Segment
                </label>
                <select name="segment_id" id="segment-select" class="w-full bg-btnSecondary border border-btnBorder rounded-lg py-2.5 px-3.5 text-sm focus:outline-none focus:border-brand-primary transition-all">
                    <option value="">— No segment (use manual contacts below) —</option>
                    <% segments.forEach(seg => { %>
                    <option value="<%= seg.id %>" <%= draft.segment_id === seg.id ? 'selected' : '' %>>
                        <%= seg.name %> (<%= (seg.contact_count||0).toLocaleString() %> contacts)
                    </option>
                    <% }) %>
                </select>
            </div>

            <div class="flex items-center gap-3">
                <div class="h-px flex-1 bg-brand-border"></div>
                <span class="text-xs text-brand-textMuted uppercase">or add individual contacts</span>
                <div class="h-px flex-1 bg-brand-border"></div>
            </div>

            <!-- Searchable contact picker -->
            <div>
                <label class="block text-xs font-medium text-brand-textMuted uppercase tracking-wide mb-1.5">
                    <i class="fa-solid fa-magnifying-glass mr-1"></i>Search Contacts (name, email, company, tags)
                </label>
                <div class="relative">
                    <input type="text" id="contact-search-input" placeholder="Type to search..."
                        class="w-full bg-btnSecondary border border-btnBorder rounded-lg py-2.5 px-3.5 text-sm focus:outline-none focus:border-brand-primary transition-all pr-10"
                        autocomplete="off">
                    <i class="fa-solid fa-spinner fa-spin absolute right-3 top-1/2 -translate-y-1/2 text-brand-textMuted text-xs hidden" id="search-spinner"></i>
                </div>

                <!-- Search results dropdown -->
                <div id="search-results" class="hidden mt-1 bg-[#181b2e] border border-brand-border rounded-xl shadow-xl overflow-hidden max-h-60 overflow-y-auto">
                    <!-- filled by JS -->
                </div>

                <!-- Selected contacts chips -->
                <div id="selected-chips" class="flex flex-wrap gap-2 mt-3 min-h-[32px]">
                    <!-- chips added dynamically -->
                </div>
                <div id="no-contacts-hint" class="text-xs text-brand-textMuted mt-1">No contacts added yet</div>
            </div>

            <!-- Hidden input storing selected IDs -->
            <input type="hidden" name="contact_ids" id="contact-ids-input" value="<%= (draft.contact_ids||[]).join(',') %>">

            <!-- Count summary -->
            <div id="audience-summary" class="text-xs text-brand-textMuted hidden">
                <i class="fa-solid fa-users mr-1 text-brand-primary"></i>
                <span id="audience-count-label"></span>
            </div>

            <div class="flex justify-between pt-2">
                <a href="/campaigns/new/step/1" class="px-5 py-2.5 bg-btnSecondary border border-btnBorder rounded-lg text-sm hover:bg-brand-border/50 transition-all">
                    <i class="fa-solid fa-arrow-left mr-2"></i>Back
                </a>
                <button type="submit" class="px-6 py-2.5 bg-brand-primary text-white rounded-lg text-sm font-semibold hover:bg-blue-500 transition-all">
                    Next: Template <i class="fa-solid fa-arrow-right ml-2"></i>
                </button>
            </div>
        </form>
    </div>
</div>
</main>
</div>
<script>
(function(){
    const btn=document.getElementById('sidebar-toggle');const sidebar=document.getElementById('sidebar');const wrapper=document.getElementById('main-wrapper');
    if(btn)btn.addEventListener('click',()=>{sidebar.classList.toggle('collapsed');wrapper.style.marginLeft=sidebar.classList.contains('collapsed')?'60px':'240px';});

    const searchInput   = document.getElementById('contact-search-input');
    const resultsBox    = document.getElementById('search-results');
    const chipsBox      = document.getElementById('selected-chips');
    const hiddenInput   = document.getElementById('contact-ids-input');
    const hintEl        = document.getElementById('no-contacts-hint');
    const summaryEl     = document.getElementById('audience-summary');
    const countLabel    = document.getElementById('audience-count-label');
    const segmentSelect = document.getElementById('segment-select');
    const spinner       = document.getElementById('search-spinner');

    // Restore previously selected contacts
    const selected = new Map(); // id → contact object

    // Load previously saved IDs from draft (simple labels for UX)
    const draftIds = hiddenInput.value ? hiddenInput.value.split(',').filter(Boolean) : [];
    draftIds.forEach(id => {
        selected.set(id, { id, email: id, first_name: '', last_name: '', company: '' });
    });
    renderChips();

    function renderChips() {
        chipsBox.innerHTML = '';
        hintEl.style.display = selected.size ? 'none' : '';
        selected.forEach((c, id) => {
            const name = [c.first_name, c.last_name].filter(Boolean).join(' ') || c.email;
            const chip = document.createElement('span');
            chip.className = 'inline-flex items-center gap-1.5 bg-brand-primary/10 border border-brand-primary/30 text-brand-primary text-xs rounded-full px-3 py-1.5';
            chip.innerHTML = `<span class="max-w-[160px] truncate">${name}${c.company ? ' · ' + c.company : ''}</span>
              <button type="button" data-id="${id}" class="remove-chip text-brand-primary/60 hover:text-red-400 transition-colors ml-0.5 text-[11px] font-bold">✕</button>`;
            chipsBox.appendChild(chip);
        });
        hiddenInput.value = Array.from(selected.keys()).join(',');
        updateSummary();
    }

    function updateSummary() {
        const segVal = segmentSelect.value;
        const manualCount = selected.size;
        if (segVal || manualCount > 0) {
            summaryEl.classList.remove('hidden');
            if (segVal && manualCount > 0) countLabel.textContent = 'Segment + ' + manualCount + ' individual contact(s)';
            else if (segVal) countLabel.textContent = 'Using segment audience';
            else countLabel.textContent = manualCount + ' contact(s) selected';
        } else {
            summaryEl.classList.add('hidden');
        }
    }

    segmentSelect.addEventListener('change', updateSummary);

    chipsBox.addEventListener('click', function(e) {
        const btn = e.target.closest('.remove-chip');
        if (!btn) return;
        selected.delete(btn.dataset.id);
        renderChips();
    });

    // Search
    let searchTimer;
    searchInput.addEventListener('input', function() {
        clearTimeout(searchTimer);
        const q = searchInput.value.trim();
        if (!q) { resultsBox.classList.add('hidden'); return; }
        spinner.classList.remove('hidden');
        searchTimer = setTimeout(function() {
            fetch('/contacts/search?q=' + encodeURIComponent(q))
                .then(r => r.json())
                .then(function(contacts) {
                    spinner.classList.add('hidden');
                    if (!contacts.length) {
                        resultsBox.innerHTML = '<div class="px-4 py-3 text-xs text-brand-textMuted">No contacts found</div>';
                    } else {
                        resultsBox.innerHTML = contacts.map(c => {
                            const name = [c.first_name, c.last_name].filter(Boolean).join(' ') || c.email;
                            const isAdded = selected.has(c.id);
                            return `<div class="search-result flex items-center gap-3 px-4 py-2.5 cursor-pointer hover:bg-white/5 transition-colors ${isAdded ? 'opacity-50 pointer-events-none' : ''}" data-contact='${JSON.stringify(c).replace(/'/g,"&#39;")}'>
                              <div class="w-7 h-7 rounded-full bg-brand-primary/20 flex items-center justify-center text-xs font-semibold text-brand-primary shrink-0">${(name[0]||'?').toUpperCase()}</div>
                              <div class="flex-1 min-w-0">
                                <div class="text-sm font-medium truncate">${name}</div>
                                <div class="text-xs text-brand-textMuted truncate">${c.email}${c.company ? ' · ' + c.company : ''}</div>
                              </div>
                              ${isAdded ? '<span class="text-[10px] text-green-400">Added</span>' : '<i class="fa-solid fa-plus text-xs text-brand-primary"></i>'}
                            </div>`;
                        }).join('');
                    }
                    resultsBox.classList.remove('hidden');
                })
                .catch(function() { spinner.classList.add('hidden'); });
        }, 300);
    });

    resultsBox.addEventListener('click', function(e) {
        const row = e.target.closest('.search-result');
        if (!row) return;
        try {
            const c = JSON.parse(row.dataset.contact.replace(/&#39;/g,"'"));
            selected.set(c.id, c);
            renderChips();
            searchInput.value = '';
            resultsBox.classList.add('hidden');
        } catch(err) {}
    });

    // Close results on outside click
    document.addEventListener('click', function(e) {
        if (!searchInput.contains(e.target) && !resultsBox.contains(e.target)) {
            resultsBox.classList.add('hidden');
        }
    });
})();
</script>
</body>
</html>
