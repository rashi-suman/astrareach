<!DOCTYPE html>
<html lang="en">
<%- include('../layout/_head', { title: campaign.name }) %>
<body class="bg-brand-dark text-gray-100 font-sans antialiased">
<%- include('../layout/_sidebar', { page: 'campaigns', user }) %>
<div id="main-wrapper" class="flex flex-col min-h-screen">
<%- include('../layout/_header', { breadcrumbs, user }) %>
<main class="flex-1 overflow-y-auto p-6" id="campaign-main">
<%
const statusCls = {
    active: 'bg-green-500/10 text-green-500 border-green-500/20',
    draft: 'bg-brand-primary/10 text-brand-primary border-brand-primary/20',
    scheduled: 'bg-cyan-500/10 text-cyan-400 border-cyan-500/20',
    paused: 'bg-amber-500/10 text-amber-500 border-amber-500/20',
    completed: 'bg-blue-500/10 text-blue-400 border-blue-500/20',
    stopped: 'bg-red-500/10 text-red-500 border-red-500/20',
    failed: 'bg-red-500/10 text-red-500 border-red-500/20',
}[campaign.status] || 'bg-brand-border text-brand-textMuted border-brand-border';
%>

    <!-- Header -->
    <div class="flex items-start justify-between mb-6">
        <div>
            <div class="flex items-center gap-3 mb-1">
                <h1 class="text-xl font-semibold"><%= campaign.name %></h1>
                <span class="px-2.5 py-0.5 rounded-full text-[10px] font-bold border capitalize <%= statusCls %>"><%= campaign.status %></span>
            </div>
            <% if (campaign.description) { %><p class="text-sm text-brand-textMuted"><%= campaign.description %></p><% } %>
            <% if (campaign.status === 'scheduled' && campaign.scheduled_start_at) { %>
            <p class="text-xs text-cyan-400/90 mt-2"><i class="fa-regular fa-clock mr-1.5"></i>Sends begin <%= new Date(campaign.scheduled_start_at).toLocaleString(undefined, { dateStyle: 'medium', timeStyle: 'short' }) %> (<%= campaign.timezone || 'UTC' %>)</p>
            <% } %>
        </div>
        <div class="flex gap-2 shrink-0 flex-wrap">
            <!-- Preview Email Template -->
            <% if (template) { %>
            <button onclick="openEmailPreview()"
                class="px-4 py-2 bg-brand-primary/10 border border-brand-primary/30 text-brand-primary hover:bg-brand-primary/20 rounded-lg text-sm font-medium transition-all">
                <i class="fa-solid fa-envelope-open-text mr-1.5"></i>Preview Email
            </button>
            <% } %>
            <!-- AI Analysis -->
            <button onclick="loadAIAnalysis()" id="ai-analysis-btn"
                class="px-4 py-2 bg-purple-600/20 border border-purple-500/40 text-purple-400 hover:bg-purple-600/30 rounded-lg text-sm font-medium transition-all">
                <i class="fa-solid fa-wand-magic-sparkles mr-1.5"></i>AI Analysis
            </button>
            <% if (campaign.status === 'draft' || campaign.status === 'scheduled') { %>
            <form action="/campaigns/<%= campaign.id %>/start" method="POST" class="inline">
                <button type="submit" class="px-4 py-2 bg-green-500/10 border border-green-500/30 text-green-500 rounded-lg text-sm font-medium hover:bg-green-500/20 transition-all"><i class="fa-solid fa-play mr-1.5"></i><%= campaign.status === 'scheduled' ? 'Start now' : 'Start' %></button>
            </form>
            <% } else if (campaign.status === 'active') { %>
            <form action="/campaigns/<%= campaign.id %>/pause" method="POST" class="inline">
                <button type="submit" class="px-4 py-2 bg-amber-500/10 border border-amber-500/30 text-amber-500 rounded-lg text-sm font-medium hover:bg-amber-500/20 transition-all"><i class="fa-solid fa-pause mr-1.5"></i>Pause</button>
            </form>
            <form action="/campaigns/<%= campaign.id %>/stop" method="POST" class="inline">
                <button type="submit" onclick="return confirm('Stop campaign?')" class="px-4 py-2 bg-red-500/10 border border-red-500/30 text-red-400 rounded-lg text-sm font-medium hover:bg-red-500/20 transition-all"><i class="fa-solid fa-stop mr-1.5"></i>Stop</button>
            </form>
            <% } else if (campaign.status === 'paused') { %>
            <form action="/campaigns/<%= campaign.id %>/resume" method="POST" class="inline">
                <button type="submit" class="px-4 py-2 bg-brand-primary/10 border border-brand-primary/30 text-brand-primary rounded-lg text-sm font-medium hover:bg-brand-primary/20 transition-all"><i class="fa-solid fa-play mr-1.5"></i>Resume</button>
            </form>
            <% } %>
        </div>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-7 gap-3 mb-6" id="stats-grid">
        <%
        const s = stats;
        const sentPct = s.total > 0 ? Math.round(s.sent / s.total * 100) : 0;
        const delivPct = s.sent > 0 ? Math.round(s.delivered / s.sent * 100) : 0;
        const openPct = s.delivered > 0 ? Math.round(s.opened / s.delivered * 100) : 0;
        const clickPct = s.opened > 0 ? Math.round(s.clicked / s.opened * 100) : 0;
        const bouncePct = s.sent > 0 ? Math.round(s.bounced / s.sent * 100) : 0;
        %>
        <div class="bg-brand-card border border-brand-border rounded-xl p-3.5">
            <p class="text-xs text-brand-textMuted uppercase tracking-wide mb-1.5">Total</p>
            <p class="text-2xl font-bold text-white"><%= (s.total||0).toLocaleString() %></p>
        </div>
        <div class="bg-brand-card border border-brand-border rounded-xl p-3.5">
            <p class="text-xs text-brand-textMuted uppercase tracking-wide mb-1.5">Sent</p>
            <p class="text-2xl font-bold text-brand-primary" id="stat-sent"><%= (s.sent||0).toLocaleString() %></p>
            <p class="text-[10px] text-brand-textMuted mt-1"><%= sentPct %>% of total</p>
        </div>
        <div class="bg-brand-card border border-brand-border rounded-xl p-3.5">
            <p class="text-xs text-brand-textMuted uppercase tracking-wide mb-1.5">Delivered</p>
            <p class="text-2xl font-bold text-teal-400" id="stat-delivered"><%= (s.delivered||0).toLocaleString() %></p>
            <p class="text-[10px] text-brand-textMuted mt-1"><%= delivPct %>%</p>
        </div>
        <div class="bg-brand-card border border-brand-border rounded-xl p-3.5">
            <p class="text-xs text-brand-textMuted uppercase tracking-wide mb-1.5">Opened</p>
            <p class="text-2xl font-bold text-brand-secondary" id="stat-opened"><%= (s.opened||0).toLocaleString() %></p>
            <p class="text-[10px] text-brand-textMuted mt-1"><%= openPct %>%</p>
        </div>
        <div class="bg-brand-card border border-brand-border rounded-xl p-3.5">
            <p class="text-xs text-brand-textMuted uppercase tracking-wide mb-1.5">Clicked</p>
            <p class="text-2xl font-bold text-green-500" id="stat-clicked"><%= (s.clicked||0).toLocaleString() %></p>
            <p class="text-[10px] text-brand-textMuted mt-1"><%= clickPct %>%</p>
        </div>
        <div class="bg-brand-card border border-brand-border rounded-xl p-3.5">
            <p class="text-xs text-brand-textMuted uppercase tracking-wide mb-1.5">Booked</p>
            <p class="text-2xl font-bold text-amber-500" id="stat-booked"><%= (s.booked||0).toLocaleString() %></p>
        </div>
        <div class="bg-brand-card border border-brand-border rounded-xl p-3.5">
            <p class="text-xs text-brand-textMuted uppercase tracking-wide mb-1.5">Bounced</p>
            <p class="text-2xl font-bold text-red-500" id="stat-bounced"><%= (s.bounced||0).toLocaleString() %></p>
            <p class="text-[10px] text-brand-textMuted mt-1"><%= bouncePct %>%</p>
        </div>
    </div>

    <!-- Progress bar -->
    <div class="bg-brand-card border border-brand-border rounded-xl p-4 mb-6">
        <div class="flex justify-between text-xs text-brand-textMuted mb-2">
            <span>Overall Progress</span>
            <span id="progress-label"><%= s.sent %> / <%= s.total %> sent (<%= sentPct %>%)</span>
        </div>
        <div class="w-full h-2 bg-brand-border rounded-full overflow-hidden">
            <div id="progress-bar" class="h-full bg-brand-primary rounded-full transition-all" style="width:<%= sentPct %>%"></div>
        </div>
    </div>

    <!-- Template info bar -->
    <% if (template) { %>
    <div class="bg-brand-card border border-brand-border rounded-xl px-5 py-3.5 mb-6 flex flex-wrap items-center justify-between gap-3">
        <div class="flex items-center gap-3 min-w-0">
            <div class="w-8 h-8 rounded-lg bg-brand-primary/10 flex items-center justify-center shrink-0">
                <i class="fa-solid fa-file-lines text-brand-primary text-xs"></i>
            </div>
            <div class="min-w-0">
                <p class="text-[11px] text-brand-textMuted uppercase tracking-wide">Email Template</p>
                <p class="text-sm font-semibold truncate"><%= template.name %></p>
            </div>
            <div class="hidden sm:block h-8 w-px bg-brand-border mx-2"></div>
            <div class="hidden sm:block min-w-0">
                <p class="text-[11px] text-brand-textMuted uppercase tracking-wide">Subject</p>
                <p class="text-sm truncate max-w-xs"><%= template.subject %></p>
            </div>
            <% if (template.booking_url) { %>
            <div class="hidden md:block h-8 w-px bg-brand-border mx-2"></div>
            <div class="hidden md:block">
                <p class="text-[11px] text-brand-textMuted uppercase tracking-wide">Booking URL</p>
                <a href="<%= template.booking_url %>" target="_blank" class="text-xs text-brand-primary hover:underline truncate block max-w-[180px]"><%= template.booking_url %></a>
            </div>
            <% } %>
        </div>
        <div class="flex items-center gap-2 shrink-0">
            <% if (template.include_unsubscribe) { %>
            <span class="px-2 py-0.5 bg-green-500/10 text-green-400 border border-green-500/20 text-[10px] rounded-full font-medium">Unsub footer on</span>
            <% } %>
            <button onclick="openEmailPreview()" class="px-3 py-1.5 bg-brand-primary text-white rounded-lg text-xs font-semibold hover:bg-blue-500 transition-all flex items-center gap-1.5">
                <i class="fa-solid fa-expand text-[10px]"></i>Full Preview
            </button>
            <a href="/templates/<%= template.id %>" target="_blank" class="px-3 py-1.5 bg-btnSecondary border border-btnBorder rounded-lg text-xs hover:bg-brand-border/50 transition-all flex items-center gap-1.5">
                <i class="fa-solid fa-arrow-up-right-from-square text-[10px]"></i>Edit Template
            </a>
        </div>
    </div>
    <% } %>

    <!-- Main Split: Contacts (7col) + Live Activity (3col) -->
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-6 mb-6">

        <!-- LEFT: Contacts Table (7/10) -->
        <div class="lg:col-span-7 bg-brand-card border border-brand-border rounded-xl overflow-hidden flex flex-col" style="max-height:640px;">
            <div class="p-4 border-b border-brand-border flex flex-col sm:flex-row sm:items-center justify-between gap-3 bg-brand-sidebar/20">
                <h2 class="font-semibold shrink-0">Contacts</h2>
                <div class="flex items-center gap-2">
                    <div class="relative">
                        <i class="fa-solid fa-magnifying-glass absolute left-2.5 top-1/2 -translate-y-1/2 text-brand-textMuted text-[10px]"></i>
                        <input type="text" id="contact-search" placeholder="Search contacts..." class="bg-brand-dark border border-brand-border rounded-lg pl-8 pr-3 py-1.5 text-xs focus:outline-none focus:border-brand-primary w-44 transition-all">
                    </div>
                    <select id="status-filter" class="bg-brand-dark border border-brand-border rounded-lg px-3 py-1.5 text-xs text-brand-textMuted focus:outline-none focus:border-brand-primary">
                        <option value="">All Statuses</option>
                        <option value="pending">Pending</option>
                        <option value="sent">Sent</option>
                        <option value="delivered">Delivered</option>
                        <option value="opened">Opened</option>
                        <option value="clicked">Clicked</option>
                        <option value="booked">Booked</option>
                        <option value="bounced">Bounced</option>
                        <option value="failed">Failed</option>
                    </select>
                </div>
            </div>
            <div class="flex-1 overflow-auto">
                <table class="w-full text-sm">
                    <thead class="text-[11px] uppercase tracking-wider text-brand-textMuted border-b border-brand-border sticky top-0 bg-brand-card">
                        <tr>
                            <th class="px-5 py-3.5 text-left font-medium">Contact</th>
                            <th class="px-5 py-3.5 text-left font-medium hidden sm:table-cell">Company</th>
                            <th class="px-5 py-3.5 text-left font-medium">Status</th>
                            <th class="px-5 py-3.5 text-left font-medium hidden md:table-cell">Last Event</th>
                            <th class="px-5 py-3.5 text-left font-medium hidden md:table-cell">Sent At</th>
                            <th class="px-5 py-3.5 text-left font-medium">Action</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-brand-border/40" id="contacts-tbody">
                        <% if (!contacts || contacts.length === 0) { %>
                        <tr><td colspan="6" class="px-5 py-8 text-center text-brand-textMuted text-sm">No contacts yet</td></tr>
                        <% } else { %>
                        <% contacts.forEach(cc => {
                            const name = [cc.first_name, cc.last_name].filter(Boolean).join(' ') || cc.email;
                            const initials = name ? name.split(' ').map(w=>w[0]).join('').slice(0,2).toUpperCase() : '??';
                            const stCls = {pending:'bg-brand-border/60 text-brand-textMuted border-brand-border',researching:'bg-amber-500/10 text-amber-500 border-amber-500/20',ready:'bg-blue-500/10 text-blue-400 border-blue-500/20',sent:'bg-brand-primary/10 text-brand-primary border-brand-primary/20',delivered:'bg-teal-500/10 text-teal-400 border-teal-500/20',opened:'bg-brand-secondary/10 text-brand-secondary border-brand-secondary/20',clicked:'bg-green-500/10 text-green-500 border-green-500/20',booked:'bg-amber-500/10 text-amber-500 border-amber-500/20',bounced:'bg-red-500/10 text-red-500 border-red-500/20',failed:'bg-red-500/10 text-red-500 border-red-500/20'}[cc.status]||'bg-brand-border/60 text-brand-textMuted border-brand-border';
                        %>
                        <tr class="hover:bg-brand-sidebar/20 transition-colors contact-row" data-name="<%= name.toLowerCase() %>" data-email="<%= cc.email.toLowerCase() %>" data-company="<%= (cc.company||'').toLowerCase() %>" data-status="<%= cc.status %>">
                            <td class="px-5 py-3.5">
                                <a href="/contacts/<%= cc.contact_id %>" class="flex items-center gap-2.5">
                                    <div class="w-7 h-7 rounded-full bg-brand-primary/15 flex items-center justify-center text-[10px] font-bold text-brand-primary shrink-0"><%= initials %></div>
                                    <div>
                                        <p class="text-sm font-medium hover:text-brand-primary truncate max-w-[130px]"><%= name %></p>
                                        <p class="text-[11px] text-brand-textMuted truncate max-w-[130px]"><%= cc.email %></p>
                                    </div>
                                </a>
                            </td>
                            <td class="px-5 py-3.5 text-xs text-brand-textMuted hidden sm:table-cell"><%= cc.company || '—' %></td>
                            <td class="px-5 py-3.5">
                                <span class="px-2 py-0.5 rounded-full text-[10px] font-bold capitalize border <%= stCls %>"><%= cc.status %></span>
                            </td>
                            <td class="px-5 py-3.5 text-xs text-brand-textMuted hidden md:table-cell"><%= cc.last_event_at ? new Date(cc.last_event_at).toLocaleDateString() : '—' %></td>
                            <td class="px-5 py-3.5 text-xs text-brand-textMuted hidden md:table-cell"><%= cc.sent_at ? new Date(cc.sent_at).toLocaleString() : '—' %></td>
                            <td class="px-5 py-3.5">
                                <a href="/contacts/<%= cc.contact_id %>" class="text-brand-primary hover:text-blue-400 text-xs font-medium transition-colors">View →</a>
                            </td>
                        </tr>
                        <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>
            <div class="border-t border-brand-border px-5 py-3 flex items-center justify-between bg-brand-sidebar/20">
                <p class="text-xs text-brand-textMuted" id="contact-count-label"><%= contacts.length %> of <%= stats.total %> contacts</p>
                <div class="flex gap-1">
                    <% if (pageNo > 1) { %><a href="/campaigns/<%= campaign.id %>?page=<%= pageNo-1 %>" class="px-3 py-1.5 text-xs bg-btnSecondary border border-btnBorder rounded hover:bg-brand-border/50 transition-all"><i class="fa-solid fa-chevron-left text-[10px]"></i> Prev</a><% } %>
                    <% if (contacts.length === 50) { %><a href="/campaigns/<%= campaign.id %>?page=<%= pageNo+1 %>" class="px-3 py-1.5 text-xs bg-btnSecondary border border-btnBorder rounded hover:bg-brand-border/50 transition-all">Next <i class="fa-solid fa-chevron-right text-[10px]"></i></a><% } %>
                </div>
            </div>
        </div>

        <!-- RIGHT: Live Activity Feed (3/10) -->
        <div class="lg:col-span-3 bg-brand-card border border-brand-border rounded-xl flex flex-col" style="max-height:640px;">
            <div class="p-4 border-b border-brand-border flex items-center justify-between">
                <h2 class="font-semibold text-sm">Live Activity</h2>
                <div class="flex items-center gap-1.5 px-2 py-1 bg-green-500/10 rounded-full">
                    <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span>
                    <span class="text-[10px] font-bold text-green-500 uppercase tracking-tighter">Live</span>
                </div>
            </div>
            <div class="flex-1 overflow-auto p-3 space-y-3" id="event-feed">
                <% if (!events || events.length === 0) { %>
                <p class="p-4 text-xs text-brand-textMuted text-center">No events yet</p>
                <% } else { %>
                <% events.forEach(ev => {
                    const name = [ev.first_name, ev.last_name].filter(Boolean).join(' ') || '—';
                    const timeAgo = (() => { const diff=Date.now()-new Date(ev.created_at).getTime(); const m=Math.floor(diff/60000); if(m<60)return m+'m ago'; const h=Math.floor(m/60); if(h<24)return h+'h ago'; return Math.floor(h/24)+'d ago'; })();
                    const evBorder = {opened:'border-l-brand-secondary',clicked:'border-l-green-500',booked:'border-l-amber-500',bounced:'border-l-red-500',delivered:'border-l-teal-400',sent:'border-l-brand-primary'}[ev.event_type] || 'border-l-brand-border';
                    const evNameColor = {opened:'text-brand-secondary',clicked:'text-green-500',booked:'text-amber-500',bounced:'text-red-500',delivered:'text-teal-400',sent:'text-brand-primary'}[ev.event_type] || 'text-white';
                    const initials2 = name.split(' ').map(w=>w[0]).join('').slice(0,2).toUpperCase();
                    const evLabel = {opened:'opened the email',clicked:'clicked a link',booked:'booked a call',bounced:'email bounced',delivered:'email delivered',sent:'email sent'}[ev.event_type] || ev.event_type;
                %>
                <div class="flex gap-3 p-2.5 rounded-lg bg-brand-dark/50 border-l-4 <%= evBorder %>">
                    <div class="w-8 h-8 rounded-full bg-brand-primary/15 flex items-center justify-center text-[10px] font-bold text-brand-primary shrink-0"><%= initials2 %></div>
                    <div class="min-w-0">
                        <p class="text-xs font-medium text-white leading-snug"><span class="<%= evNameColor %>"><%= name %></span> <%= evLabel %></p>
                        <p class="text-[10px] text-brand-textMuted mt-0.5"><%= timeAgo %></p>
                    </div>
                </div>
                <% }) %>
                <% } %>
            </div>
            <div class="p-3 border-t border-brand-border text-center">
                <a href="/campaigns/<%= campaign.id %>?page=1" class="text-xs font-semibold text-brand-primary hover:text-blue-400 transition-colors">View all contacts →</a>
            </div>
        </div>
    </div>

    <!-- Engagement Chart -->
    <div class="bg-brand-card border border-brand-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-4">
            <h2 class="font-semibold">Engagement Over Time</h2>
            <div class="flex gap-2 text-[10px]">
                <span class="flex items-center gap-1.5 text-brand-primary"><span class="w-3 h-0.5 bg-brand-primary rounded-full inline-block"></span>Sent</span>
                <span class="flex items-center gap-1.5 text-brand-secondary"><span class="w-3 h-0.5 bg-brand-secondary rounded-full inline-block"></span>Opened</span>
                <span class="flex items-center gap-1.5 text-green-500"><span class="w-3 h-0.5 bg-green-500 rounded-full inline-block"></span>Clicked</span>
            </div>
        </div>
        <div class="relative h-52">
            <canvas id="engagement-chart"></canvas>
        </div>
    </div>
</main>
</div>
<div id="toast-container"></div>

<% if (template) { %>
<!-- Email Preview Modal -->
<div id="email-preview-modal" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.85);flex-direction:column;">
    <!-- Header -->
    <div style="display:flex;align-items:center;justify-content:space-between;padding:12px 20px;background:#0f1623;border-bottom:1px solid #2a3347;flex-shrink:0;">
        <div style="display:flex;align-items:center;gap:12px;">
            <div style="width:36px;height:36px;border-radius:8px;background:rgba(98,60,234,0.2);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <i class="fa-solid fa-envelope" style="color:#623CEA;font-size:13px;"></i>
            </div>
            <div>
                <p style="font-size:13px;font-weight:600;color:#fff;margin:0;" id="ep-subject">Subject</p>
                <p style="font-size:11px;color:#8b9ab0;margin:0;">Template: <span id="ep-tpl-name" style="color:#a78bfa;"></span> &nbsp;·&nbsp; Previewed with sample data</p>
            </div>
        </div>
        <button onclick="closeEmailPreview()" style="width:32px;height:32px;border-radius:8px;background:#2a3347;border:none;color:#8b9ab0;cursor:pointer;font-size:15px;display:flex;align-items:center;justify-content:center;" onmouseover="this.style.background='rgba(239,68,68,0.2)';this.style.color='#f87171';" onmouseout="this.style.background='#2a3347';this.style.color='#8b9ab0';">
            <i class="fa-solid fa-xmark"></i>
        </button>
    </div>
    <!-- Device toggle -->
    <div style="display:flex;align-items:center;justify-content:center;gap:8px;padding:8px;background:#0a0e18;border-bottom:1px solid #1e2535;flex-shrink:0;">
        <button onclick="setEPWidth('100%','ep-d')" id="ep-d" style="padding:4px 12px;border-radius:6px;border:1px solid rgba(98,60,234,0.4);background:rgba(98,60,234,0.2);color:#a78bfa;font-size:11px;cursor:pointer;"><i class="fa-solid fa-desktop" style="margin-right:4px;"></i>Desktop</button>
        <button onclick="setEPWidth('640px','ep-t')" id="ep-t" style="padding:4px 12px;border-radius:6px;border:1px solid transparent;background:transparent;color:#8b9ab0;font-size:11px;cursor:pointer;"><i class="fa-solid fa-tablet-screen-button" style="margin-right:4px;"></i>Tablet</button>
        <button onclick="setEPWidth('390px','ep-m')" id="ep-m" style="padding:4px 12px;border-radius:6px;border:1px solid transparent;background:transparent;color:#8b9ab0;font-size:11px;cursor:pointer;"><i class="fa-solid fa-mobile-screen" style="margin-right:4px;"></i>Mobile</button>
    </div>
    <!-- Preview area -->
    <div style="flex:1;overflow:auto;background:#1a1a1a;display:flex;align-items:flex-start;justify-content:center;padding:24px;">
        <div id="ep-wrapper" style="width:100%;max-width:100%;transition:width 0.25s ease;background:#fff;border-radius:12px;overflow:hidden;box-shadow:0 25px 60px rgba(0,0,0,0.6);">
            <iframe id="ep-frame" style="width:100%;min-height:80vh;border:none;display:block;" srcdoc=""></iframe>
        </div>
    </div>
</div>

<script>
const _epTemplate = {
    subject: <%- JSON.stringify(template.subject || '') %>,
    body: <%- JSON.stringify(template.body_html || '') %>,
    name: <%- JSON.stringify(template.name || '') %>,
};
const _epSample = {
    first_name:'Rohit', last_name:'Sharma', company:'Astrabyte', job_title:'Founder',
    industry:'IT & Software', city:'Bangalore', country:'India',
    website:'https://astrabytesolutions.com',
    booking_url: <%- JSON.stringify(template.booking_url || 'https://astrabytesolutions.com/book-call') %>,
};

function _epApplyVars(str) {
    let out = str;
    Object.entries(_epSample).forEach(([k,v]) => { out = out.split('{{'+k+'}}').join(v); });
    return out;
}

function openEmailPreview() {
    const modal = document.getElementById('email-preview-modal');
    document.getElementById('ep-subject').textContent = _epApplyVars(_epTemplate.subject);
    document.getElementById('ep-tpl-name').textContent = _epTemplate.name;
    document.getElementById('ep-frame').srcdoc = _epApplyVars(_epTemplate.body) ||
        '<p style="color:#888;padding:40px;font-family:Inter,sans-serif;">This template has no body content.</p>';
    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden';
}

function closeEmailPreview() {
    document.getElementById('email-preview-modal').style.display = 'none';
    document.body.style.overflow = '';
}

function setEPWidth(w, activeId) {
    document.getElementById('ep-wrapper').style.width = w;
    document.getElementById('ep-wrapper').style.maxWidth = w;
    ['ep-d','ep-t','ep-m'].forEach(id => {
        const el = document.getElementById(id);
        el.style.background = 'transparent';
        el.style.color = '#8b9ab0';
        el.style.borderColor = 'transparent';
    });
    const el = document.getElementById(activeId);
    if (el) { el.style.background = 'rgba(98,60,234,0.2)'; el.style.color = '#a78bfa'; el.style.borderColor = 'rgba(98,60,234,0.4)'; }
}

document.addEventListener('keydown', e => { if (e.key === 'Escape') closeEmailPreview(); });
</script>
<% } %>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
<script>
const campaignId = '<%= campaign.id %>';
const campaignStatus = '<%= campaign.status %>';

(function(){
    const btn=document.getElementById('sidebar-toggle');const sidebar=document.getElementById('sidebar');const wrapper=document.getElementById('main-wrapper');
    if(btn)btn.addEventListener('click',()=>{sidebar.classList.toggle('collapsed');wrapper.style.marginLeft=sidebar.classList.contains('collapsed')?'60px':'240px';});

    // --- Contact search + status filter ---
    const searchInput = document.getElementById('contact-search');
    const statusFilter = document.getElementById('status-filter');
    const rows = document.querySelectorAll('.contact-row');

    function filterContacts() {
        const q = (searchInput ? searchInput.value.toLowerCase() : '');
        const st = (statusFilter ? statusFilter.value : '');
        let shown = 0;
        rows.forEach(row => {
            const nameMatch = !q || row.dataset.name.includes(q) || row.dataset.email.includes(q) || row.dataset.company.includes(q);
            const statusMatch = !st || row.dataset.status === st;
            const visible = nameMatch && statusMatch;
            row.style.display = visible ? '' : 'none';
            if (visible) shown++;
        });
        const lbl = document.getElementById('contact-count-label');
        if (lbl) lbl.textContent = shown + ' of <%= stats.total %> contacts';
    }

    if (searchInput) searchInput.addEventListener('input', filterContacts);
    if (statusFilter) statusFilter.addEventListener('change', filterContacts);

    // --- Engagement Chart ---
    (function initChart() {
        const ctx = document.getElementById('engagement-chart');
        if (!ctx) return;
        fetch('/campaigns/' + campaignId + '/events-chart')
            .then(r => r.json())
            .then(data => {
                new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: data.labels || [],
                        datasets: [
                            { label: 'Sent', data: data.sent || [], borderColor: '#4f7ef8', backgroundColor: 'rgba(79,126,248,0.08)', fill: true, tension: 0.4, pointRadius: 2, borderWidth: 2 },
                            { label: 'Opened', data: data.opened || [], borderColor: '#a78bfa', backgroundColor: 'rgba(167,139,250,0.08)', fill: true, tension: 0.4, pointRadius: 2, borderWidth: 2 },
                            { label: 'Clicked', data: data.clicked || [], borderColor: '#22c55e', backgroundColor: 'rgba(34,197,94,0.08)', fill: true, tension: 0.4, pointRadius: 2, borderWidth: 2 },
                        ]
                    },
                    options: {
                        responsive: true, maintainAspectRatio: false,
                        plugins: { legend: { display: false }, tooltip: { mode: 'index', intersect: false, backgroundColor: '#1e2535', titleColor: '#fff', bodyColor: '#8b9ab0', borderColor: '#2a3347', borderWidth: 1 } },
                        scales: {
                            x: { grid: { color: 'rgba(42,51,71,0.5)' }, ticks: { color: '#8b9ab0', font: { size: 10 } } },
                            y: { grid: { color: 'rgba(42,51,71,0.5)' }, ticks: { color: '#8b9ab0', font: { size: 10 } }, beginAtZero: true }
                        }
                    }
                });
            })
            .catch(() => {
                // Render empty chart on error
                new Chart(ctx, { type: 'line', data: { labels: [], datasets: [] }, options: { responsive: true, maintainAspectRatio: false } });
            });
    })();

    // --- Live poll stats if campaign is active ---
    if (campaignStatus === 'active' || campaignStatus === 'paused') {
        setInterval(() => {
            fetch('/campaigns/' + campaignId + '/stats')
                .then(r => r.json())
                .then(d => {
                    const el = (id) => document.getElementById(id);
                    if (el('stat-sent')) el('stat-sent').textContent = (d.sent||0).toLocaleString();
                    if (el('stat-delivered')) el('stat-delivered').textContent = (d.delivered||0).toLocaleString();
                    if (el('stat-opened')) el('stat-opened').textContent = (d.opened||0).toLocaleString();
                    if (el('stat-clicked')) el('stat-clicked').textContent = (d.clicked||0).toLocaleString();
                    if (el('stat-booked')) el('stat-booked').textContent = (d.booked||0).toLocaleString();
                    if (el('stat-bounced')) el('stat-bounced').textContent = (d.bounced||0).toLocaleString();
                    const pct = d.total > 0 ? Math.round(d.sent / d.total * 100) : 0;
                    if (el('progress-bar')) el('progress-bar').style.width = pct + '%';
                    if (el('progress-label')) el('progress-label').textContent = (d.sent||0) + ' / ' + (d.total||0) + ' sent (' + pct + '%)';
                })
                .catch(() => {});
        }, 10000);
    }
    // AI Analysis
    window.loadAIAnalysis = function() {
        const btn = document.getElementById('ai-analysis-btn');
        const panel = document.getElementById('ai-analysis-panel');
        if (panel) { panel.classList.toggle('hidden'); return; }

        btn.disabled = true;
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin mr-1.5"></i>Analysing…';

        fetch('/campaigns/' + campaignId + '/ai-analysis')
            .then(r => r.json())
            .then(data => {
                btn.disabled = false;
                btn.innerHTML = '<i class="fa-solid fa-wand-magic-sparkles mr-1.5"></i>AI Analysis';

                const gradeColor = { A:'text-green-400', B:'text-blue-400', C:'text-amber-400', D:'text-red-400' }[data.overall_grade] || 'text-white';
                const priorityBadge = p => ({high:'bg-red-500/20 text-red-400',med:'bg-amber-500/20 text-amber-400',low:'bg-green-500/20 text-green-400'}[p]||'bg-brand-border text-brand-textMuted');

                const recsHtml = (data.recommendations||[]).map(r => `
                    <div class="flex gap-3 p-3 bg-brand-sidebar rounded-lg">
                        <span class="px-1.5 py-0.5 rounded text-[10px] font-bold shrink-0 ${priorityBadge(r.priority)}">${(r.priority||'').toUpperCase()}</span>
                        <div><p class="text-xs font-semibold mb-0.5">${r.title||''}</p><p class="text-xs text-brand-textMuted">${r.description||''}</p></div>
                    </div>`).join('');

                const html = `<div id="ai-analysis-panel" class="mt-6 bg-brand-card border border-purple-500/30 rounded-xl p-5">
                    <div class="flex items-center justify-between mb-4">
                        <div class="flex items-center gap-2">
                            <i class="fa-solid fa-wand-magic-sparkles text-purple-400"></i>
                            <h3 class="font-semibold text-sm">AI Campaign Analysis</h3>
                        </div>
                        <span class="text-3xl font-black ${gradeColor}">${data.overall_grade||'—'}</span>
                    </div>
                    <p class="text-sm text-brand-textMuted mb-4">${data.summary||''}</p>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-4">${recsHtml}</div>
                    <div class="grid grid-cols-2 gap-3 text-xs">
                        <div class="bg-brand-sidebar rounded-lg p-3"><p class="text-brand-textMuted mb-1">Best Send Time</p><p class="font-medium">${data.best_send_time||'—'}</p></div>
                        <div class="bg-brand-sidebar rounded-lg p-3"><p class="text-brand-textMuted mb-1">Audience Insight</p><p class="font-medium">${data.audience_insights||'—'}</p></div>
                    </div>
                </div>`;
                document.getElementById('campaign-main').insertAdjacentHTML('beforeend', html);
            })
            .catch(() => {
                btn.disabled = false;
                btn.innerHTML = '<i class="fa-solid fa-wand-magic-sparkles mr-1.5"></i>AI Analysis';
                window.toastError && window.toastError('AI analysis failed. Please try again.');
            });
    };
})();
</script>
</body>
</html>
